<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme -->
    <style name="Base.Theme.SynapseMIS" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">#6C63FF</item>
        <item name="colorPrimaryVariant">#5A55D8</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- Secondary colors -->
        <item name="colorSecondary">#6C63FF</item>
        <item name="colorSecondaryVariant">#5A55D8</item>
        <item name="colorOnSecondary">#FFFFFF</item>

        <!-- Background -->
        <item name="android:colorBackground">#F8F9FA</item>
        <item name="colorSurface">#FFFFFF</item>
        <item name="colorOnSurface">#1A1A1A</item>

        <!-- TextInputLayout -->
        <item name="textInputStyle">@style/Widget.Synapse.TextInputLayout</item>

        <!-- Force light dialogs -->
        <item name="alertDialogTheme">@style/LightAlertDialog</item>
        <item name="materialAlertDialogTheme">@style/LightAlertDialog</item>
    </style>

    <style name="Theme.SynapseMIS" parent="Base.Theme.SynapseMIS" />

    <!-- TextInputLayout Style -->
    <style name="Widget.Synapse.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">#E0E0E0</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="hintTextColor">#9E9E9E</item>
        <item name="android:textColorHint">#9E9E9E</item>
    </style>

    <!-- Dialog Animation -->
    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@anim/slide_in_up</item>
        <item name="android:windowExitAnimation">@anim/slide_out_down</item>
    </style>

    <!-- Light Alert Dialog - Works on both light and dark mode devices -->
    <style name="LightAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="android:background">@android:color/white</item>
        <item name="colorSurface">@android:color/white</item>
        <item name="colorOnSurface">#000000</item>
        <item name="android:textColorPrimary">#000000</item>
        <item name="android:textColorSecondary">#666666</item>
        <item name="materialAlertDialogTitleTextStyle">@style/MaterialAlertDialog.Title.Text.Light</item>
        <item name="materialAlertDialogBodyTextStyle">@style/MaterialAlertDialog.Body.Text.Light</item>
        <item name="buttonBarPositiveButtonStyle">@style/CustomDialogButton.Positive</item>
        <item name="buttonBarNegativeButtonStyle">@style/CustomDialogButton.Negative</item>
    </style>

    <!-- Custom Alert Dialog (Alternative style) -->
    <style name="CustomAlertDialog" parent="Theme.MaterialComponents.Light.Dialog.Alert">
        <item name="colorPrimary">#6C63FF</item>
        <item name="colorAccent">#5A55D8</item>
        <item name="android:background">@drawable/splash_gradient_background</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">#666666</item>
        <item name="buttonBarPositiveButtonStyle">@style/CustomDialogButton.Positive</item>
        <item name="buttonBarNegativeButtonStyle">@style/CustomDialogButton.Negative</item>
    </style>

    <style name="CustomAlertDialog_Schedule_Exam" parent="Theme.MaterialComponents.Light.Dialog.Alert">
        <item name="colorPrimary">#6C63FF</item>
        <item name="colorAccent">#5A55D8</item>
        <item name="android:background">#0F0F23</item>
        <item name="android:textColorPrimary">#FFFFFF</item>
        <item name="android:textColorSecondary">@color/grey</item>
        <item name="buttonBarPositiveButtonStyle">@style/CustomDialogButton.Positive</item>
        <item name="buttonBarNegativeButtonStyle">@style/CustomDialogButton.Negative</item>
    </style>

    <!-- Dialog Title Text Style -->
    <style name="MaterialAlertDialog.Title.Text.Light" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Dialog Body Text Style -->
    <style name="MaterialAlertDialog.Body.Text.Light" parent="MaterialAlertDialog.MaterialComponents.Body.Text">
        <item name="android:textColor">#333333</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- Positive Button Style -->
    <style name="CustomDialogButton.Positive" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#6C63FF</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- Negative Button Style -->
    <style name="CustomDialogButton.Negative" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#666666</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- Custom Chip Filter Style -->
    <style name="Widget.Synapse.Chip.Filter" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="chipBackgroundColor">@color/chip_background_color</item>
        <item name="chipStrokeColor">@color/chip_stroke_color</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipCornerRadius">16dp</item>
        <item name="android:textColor">@color/chip_text_color</item>
        <item name="android:textSize">14sp</item>
        <item name="checkedIconVisible">true</item>
        <item name="chipIconTint">@color/chip_icon_tint</item>
    </style>
</resources>