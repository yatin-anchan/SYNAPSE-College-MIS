<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/splash_gradient_background">

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Course Name"
        app:boxBackgroundColor="#22FFFFFF"
        app:boxStrokeColor="@color/splash_accent"
        app:hintTextColor="@color/splash_accent"
        android:layout_marginBottom="12dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/course_name_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:inputType="textCapWords" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Course Code"
        app:boxBackgroundColor="#22FFFFFF"
        app:boxStrokeColor="@color/splash_accent"
        app:hintTextColor="@color/splash_accent"
        android:layout_marginBottom="12dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/course_code_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:inputType="textCapCharacters" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Duration (e.g., 3 Years)"
        app:boxBackgroundColor="#22FFFFFF"
        app:boxStrokeColor="@color/splash_accent"
        app:hintTextColor="@color/splash_accent"
        android:layout_marginBottom="12dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/duration_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:inputType="text" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Total Semesters"
        app:boxBackgroundColor="#22FFFFFF"
        app:boxStrokeColor="@color/splash_accent"
        app:hintTextColor="@color/splash_accent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/semesters_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:inputType="number"
            android:text="6" />
    </com.google.android.material.textfield.TextInputLayout>
</LinearLayout>
