<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_gradient_background">

    <!-- AppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/toolbar_gradient">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:elevation="4dp"
            app:titleTextColor="@android:color/white"
            app:subtitleTextColor="#B0FFFFFF" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Subject Name -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="#667EEA"
                app:boxBackgroundColor="#331A1A3E"
                app:startIconDrawable="@drawable/ic_book"
                app:startIconTint="#4FACFE">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Subject Name"
                    android:textColor="@android:color/white"
                    android:textColorHint="#B0FFFFFF"
                    android:textSize="16sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Subject Code -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="#667EEA"
                app:boxBackgroundColor="#331A1A3E"
                app:startIconDrawable="@drawable/ic_code"
                app:startIconTint="#4FACFE">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Subject Code (CS101)"
                    android:textColor="@android:color/white"
                    android:textColorHint="#B0FFFFFF"
                    android:textSize="16sp"
                    android:maxLength="10"
                    android:inputType="textCapCharacters" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Credits -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="#6C63FF"
                app:boxBackgroundColor="#331A1A3E"
                app:startIconDrawable="@drawable/ic_credit"
                app:startIconTint="#6C63FF">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCredits"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Credits (4)"
                    android:text="4"
                    android:textColor="@android:color/white"
                    android:textColorHint="#B0FFFFFF"
                    android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ✅ FIXED Type Dropdown -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                app:boxStrokeColor="#4FACFE"
                app:boxBackgroundColor="#331A1A3E"
                app:startIconDrawable="@drawable/ic_type"
                app:startIconTint="#4FACFE">

                <AutoCompleteTextView
                    android:id="@+id/etType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Type (Theory/Practical)"
                    android:textColor="@android:color/white"
                    android:textColorHint="#B0FFFFFF"
                    android:inputType="none"
                    android:focusable="false"
                    android:clickable="true"
                    android:dropDownAnchor="@id/etType"
                    android:dropDownHeight="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ✅ FIXED Semester Dropdown -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                app:boxStrokeColor="#6C63FF"
                app:boxBackgroundColor="#331A1A3E"
                app:startIconDrawable="@drawable/ic_semester"
                app:startIconTint="#6C63FF">

                <AutoCompleteTextView
                    android:id="@+id/etSemester"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Semester (Sem 1-8)"
                    android:textColor="@android:color/white"
                    android:textColorHint="#B0FFFFFF"
                    android:inputType="none"
                    android:focusable="false"
                    android:clickable="true"
                    android:dropDownAnchor="@id/etSemester"
                    android:dropDownHeight="wrap_content" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="bottom"
        android:padding="20dp"
        android:layout_marginBottom="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDelete"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="12dp"
            android:text="Delete"
            android:textColor="#FFFF4444"
            app:strokeColor="#FFFF4444"
            app:strokeWidth="2dp"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Save Subject"
            app:backgroundTint="#6C63FF"
            app:icon="@drawable/ic_save"
            app:iconTint="@android:color/white"
            app:iconGravity="start"
            app:iconPadding="12dp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
