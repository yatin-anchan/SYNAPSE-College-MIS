<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#331A1A3E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_glass_effect"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Left Side - Room Info -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/room_no_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Room: 101"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/splash_accent"/>

                <TextView
                    android:id="@+id/teacher_name_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dr. John Doe"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/class_name_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CS - Sem 5 A (Computer Science)"
                    android:textColor="@color/splash_text_secondary"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/status_text"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Present"
                    android:textSize="12sp"
                    android:textColor="@android:color/white"
                    app:chipBackgroundColor="#4CAF50"
                    android:layout_marginTop="8dp"
                    app:chipStrokeWidth="0dp"
                    style="@style/Widget.MaterialComponents.Chip.Action"/>
            </LinearLayout>

            <!-- Right Side - Action Buttons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <ImageButton
                    android:id="@+id/btn_edit"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_edit"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Edit"
                    app:tint="@color/splash_accent"
                    android:padding="8dp"/>

                <ImageButton
                    android:id="@+id/btn_delete"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:src="@drawable/ic_delete"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Delete"
                    android:layout_marginTop="4dp"
                    app:tint="#F44336"
                    android:padding="8dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>