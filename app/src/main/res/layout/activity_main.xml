<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/night_sky_gradient">

    <!-- Animated Stars Container -->
    <RelativeLayout
        android:id="@+id/stars_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Stars will be added programmatically -->

    </RelativeLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- Logo -->
        <ImageView
            android:id="@+id/app_logo"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:src="@drawable/ic_synapse_logo"
            android:layout_marginBottom="24dp"
            android:elevation="8dp" />

        <!-- App Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYNAPSE"
            android:textColor="@android:color/white"
            android:textSize="42sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.1"
            android:elevation="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Royal College Management System"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:alpha="0.8"
            android:elevation="8dp"
            android:layout_marginBottom="64dp" />

        <!-- Glassmorphism Buttons Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="16dp"
            app:cardBackgroundColor="#33FFFFFF"
            android:layout_marginHorizontal="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="32dp"
                android:background="@drawable/card_glass_effect">

                <!-- Login Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_login"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="Login"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:icon="@drawable/ic_login"
                    app:iconGravity="start"
                    app:iconSize="24dp"
                    app:backgroundTint="@color/splash_accent"
                    app:cornerRadius="16dp"
                    android:elevation="8dp"
                    android:layout_marginBottom="16dp" />

                <!-- Divider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginVertical="8dp">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@android:color/white"
                        android:alpha="0.3" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OR"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:alpha="0.6"
                        android:paddingHorizontal="16dp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="@android:color/white"
                        android:alpha="0.3" />

                </LinearLayout>

                <!-- New Student Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_new_student"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:text="Apply as New Student"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    app:icon="@drawable/ic_person_add"
                    app:iconGravity="start"
                    app:iconSize="24dp"
                    app:iconTint="@android:color/white"
                    app:strokeColor="@android:color/white"
                    app:strokeWidth="2dp"
                    app:cornerRadius="16dp"
                    android:elevation="8dp"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Footer -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="© 2026 Royal College, Mumbai"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:alpha="0.6"
            android:layout_marginTop="48dp" />

    </LinearLayout>

</FrameLayout>
