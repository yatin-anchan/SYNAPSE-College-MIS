<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/splash_card_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tv_student_name"
            android:text="Student Name"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/splash_text_primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tv_roll_number"
            android:text="Roll: 01"
            android:textColor="@color/splash_text_secondary"
            android:layout_marginTop="2dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/tv_email"
            android:text="student@email.com"
            android:textColor="@color/splash_text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_toggle_status"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:text="Present"
            android:textStyle="bold"
            app:cornerRadius="10dp"
            app:backgroundTint="@color/status_success"/>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>