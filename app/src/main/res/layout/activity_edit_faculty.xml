<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_gradient_background"
    android:fitsSystemWindows="true">

    <!-- AppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:fitsSystemWindows="true">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/toolbar_gradient"
            app:title="Edit Faculty"
            app:titleTextColor="@android:color/white"
            app:navigationIcon="?attr/homeAsUpIndicator" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Profile Photo Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#331A1A3E">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center"
                    android:background="@drawable/card_glass_effect">

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/profile_image"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:src="@drawable/ic_person"
                        app:civ_border_width="3dp"
                        app:civ_border_color="@color/splash_accent" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_change_photo"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Change Photo"
                        android:textColor="@color/splash_accent"
                        android:layout_marginTop="12dp"
                        app:icon="@drawable/ic_camera"
                        app:iconTint="@color/splash_accent" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Basic Information -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Basic Information"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:shadowColor="#6C63FF"
                android:shadowRadius="8" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#331A1A3E">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/card_glass_effect">

                    <!-- Employee ID (Read-only) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:boxBackgroundMode="outline"
                        app:boxBackgroundColor="#1A1A3E"
                        app:boxStrokeColor="@color/splash_accent"
                        app:hintTextColor="@color/splash_text_secondary"
                        app:startIconDrawable="@drawable/ic_badge"
                        app:startIconTint="@color/splash_accent"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/employee_id_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Employee ID"
                            android:enabled="false"
                            android:inputType="text"
                            android:textColor="@color/splash_text_color"
                            android:textColorHint="@color/splash_text_secondary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Full Name -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/name_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:boxBackgroundMode="outline"
                        app:boxBackgroundColor="#1A1A3E"
                        app:boxStrokeColor="@color/splash_accent"
                        app:hintTextColor="@color/splash_text_secondary"
                        app:startIconDrawable="@drawable/ic_person"
                        app:startIconTint="@color/splash_accent"
                        app:errorEnabled="true"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/name_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Full Name *"
                            android:inputType="textPersonName"
                            android:textColor="@color/splash_text_color"
                            android:textColorHint="@color/splash_text_secondary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Email (Read-only) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:boxBackgroundMode="outline"
                        app:boxBackgroundColor="#1A1A3E"
                        app:boxStrokeColor="@color/splash_accent"
                        app:hintTextColor="@color/splash_text_secondary"
                        app:startIconDrawable="@drawable/ic_email"
                        app:startIconTint="@color/splash_accent"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/email_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Email Address"
                            android:enabled="false"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/splash_text_color"
                            android:textColorHint="@color/splash_text_secondary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Mobile Number -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/mobile_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxBackgroundMode="outline"
                        app:boxBackgroundColor="#1A1A3E"
                        app:boxStrokeColor="@color/splash_accent"
                        app:hintTextColor="@color/splash_text_secondary"
                        app:startIconDrawable="@drawable/ic_phone"
                        app:startIconTint="@color/splash_accent"
                        app:errorEnabled="true"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/mobile_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Mobile Number *"
                            android:inputType="phone"
                            android:maxLength="10"
                            android:textColor="@color/splash_text_color"
                            android:textColorHint="@color/splash_text_secondary" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Professional Information -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Professional Information"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:shadowColor="#6C63FF"
                android:shadowRadius="8" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#331A1A3E">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/card_glass_effect">

                    <!-- Department -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:boxBackgroundMode="outline"
                        app:boxBackgroundColor="#1A1A3E"
                        app:boxStrokeColor="@color/splash_accent"
                        app:hintTextColor="@color/splash_text_secondary"
                        app:startIconDrawable="@drawable/ic_departments"
                        app:startIconTint="@color/splash_accent"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                        <AutoCompleteTextView
                            android:id="@+id/department_dropdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Department"
                            android:inputType="none"
                            android:textColor="@color/splash_text_color"
                            android:textColorHint="@color/splash_text_secondary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Designation -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:boxBackgroundMode="outline"
                        app:boxBackgroundColor="#1A1A3E"
                        app:boxStrokeColor="@color/splash_accent"
                        app:hintTextColor="@color/splash_text_secondary"
                        app:startIconDrawable="@drawable/ic_work"
                        app:startIconTint="@color/splash_accent"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/designation_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Designation"
                            android:inputType="text"
                            android:textColor="@color/splash_text_color"
                            android:textColorHint="@color/splash_text_secondary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Qualifications -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:boxBackgroundMode="outline"
                        app:boxBackgroundColor="#1A1A3E"
                        app:boxStrokeColor="@color/splash_accent"
                        app:hintTextColor="@color/splash_text_secondary"
                        app:startIconDrawable="@drawable/ic_education"
                        app:startIconTint="@color/splash_accent"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/qualifications_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Qualifications (e.g., M.Tech, PhD)"
                            android:inputType="text"
                            android:textColor="@color/splash_text_color"
                            android:textColorHint="@color/splash_text_secondary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Experience -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxBackgroundMode="outline"
                        app:boxBackgroundColor="#1A1A3E"
                        app:boxStrokeColor="@color/splash_accent"
                        app:hintTextColor="@color/splash_text_secondary"
                        app:startIconDrawable="@drawable/ic_experience"
                        app:startIconTint="@color/splash_accent"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/experience_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Years of Experience"
                            android:inputType="text"
                            android:textColor="@color/splash_text_color"
                            android:textColorHint="@color/splash_text_secondary" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Subjects Section -->
            <!-- Subjects Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Subjects Teaching"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:shadowColor="#6C63FF"
                android:shadowRadius="8" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#331A1A3E">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/card_glass_effect">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/subjects_chip_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:chipSpacingHorizontal="8dp" />

                    <TextView
                        android:id="@+id/no_subjects_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No subjects assigned yet"
                        android:textColor="@color/splash_text_secondary"
                        android:textSize="14sp"
                        android:visibility="gone"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Note: Subjects can be managed from the subject management section"
                        android:textColor="@color/splash_text_secondary"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp"
                        android:alpha="0.7" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <!-- Update Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_update_faculty"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Update Faculty"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                app:cornerRadius="12dp"
                app:backgroundTint="@color/splash_accent"
                android:textColor="@android:color/white"
                android:elevation="4dp"
                app:icon="@drawable/ic_check"
                app:iconTint="@android:color/white"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp" />

            <!-- Loading Progress -->
            <ProgressBar
                android:id="@+id/loading_progress"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/splash_accent"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
