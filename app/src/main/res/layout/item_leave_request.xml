<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#401A1A3E"
    app:strokeColor="#FF667EEA"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/card_glass_effect">

        <!-- Header: Applicant Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="John Doe"
                android:id="@+id/applicant_name"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:maxLines="1"
                android:ellipsize="end" />

            <ImageView
                android:id="@+id/btn_details"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_dialog_info"
                app:tint="#667EEA"
                android:layout_marginStart="8dp"
                android:padding="4dp"
                android:contentDescription="View details" />
        </LinearLayout>

        <TextView
            android:id="@+id/applicant_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Faculty"
            android:textSize="12sp"
            android:textColor="#FF667EEA"
            android:layout_marginTop="2dp" />

        <!-- Dates -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/date_range"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="01/02/2026 → 03/02/2026"
                android:textSize="14sp"
                android:textColor="@android:color/white"
                android:alpha="0.9" />

            <TextView
                android:id="@+id/number_of_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3 days"
                android:textSize="12sp"
                android:textColor="#FF4FACFE"
                android:textStyle="bold"
                android:background="@drawable/pill_background"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp" />
        </LinearLayout>

        <!-- Reason -->
        <TextView
            android:id="@+id/reason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Personal medical emergency"
            android:textSize="14sp"
            android:textColor="@android:color/white"
            android:alpha="0.9"
            android:layout_marginTop="8dp"
            android:maxLines="2"
            android:ellipsize="end" />

        <!-- Status Chip -->
        <com.google.android.material.chip.Chip
            android:id="@+id/status_chip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Pending"
            android:textSize="12sp"
            android:textStyle="bold"
            app:chipCornerRadius="8dp"
            app:checkedIcon="@null" />

        <!-- Action Buttons (only for pending) -->
        <LinearLayout
            android:id="@+id/action_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <Button
                android:id="@+id/btn_reject"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:text="Reject"
                android:textSize="12sp"
                app:strokeColor="#FFFF4444"
                app:strokeWidth="1dp"
                android:textColor="#FFFF4444" />

            <Button
                android:id="@+id/btn_approve"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Approve"
                android:textSize="12sp" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
