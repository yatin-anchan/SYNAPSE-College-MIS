<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#331A1A3E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_glass_effect"
        android:padding="16dp">

        <!-- Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/subject_icon"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:src="@drawable/ic_book"
                app:tint="@color/white"
                android:padding="8dp"
                android:background="@drawable/circle_gradient" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/subject_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Subject Name"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/subject_code"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SUB001"
                    android:textColor="@color/splash_text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <com.google.android.material.chip.Chip
                    android:id="@+id/type_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Theory"
                    android:textSize="10sp"
                    app:chipBackgroundColor="@android:color/holo_blue_dark"
                    android:textColor="@android:color/white" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/credits_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4 Credits"
                    android:textSize="9sp"
                    android:layout_marginTop="4dp"
                    app:chipBackgroundColor="@color/splash_accent"
                    android:textColor="@android:color/white" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFFFFF"
            android:layout_marginVertical="12dp" />

        <!-- Faculty Assignment Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/faculty_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="No faculty assigned"
                android:textColor="@color/splash_text_secondary"
                android:textSize="13sp"
                android:drawableStart="@drawable/ic_person"
                android:drawablePadding="6dp"
                android:drawableTint="@color/splash_text_secondary"
                android:gravity="center_vertical" />

            <ImageView
                android:id="@+id/btn_assign_faculty"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_person_add"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/splash_accent"
                android:contentDescription="Assign Faculty" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFFFFF"
            android:layout_marginVertical="12dp" />

        <!-- Actions Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <ImageView
                android:id="@+id/btn_edit"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_edit"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@android:color/holo_orange_light"
                android:contentDescription="Edit Subject" />

            <ImageView
                android:id="@+id/btn_delete"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_delete"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@android:color/holo_red_light"
                android:contentDescription="Delete Subject"
                android:layout_marginStart="8dp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
