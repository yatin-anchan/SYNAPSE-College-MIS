<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/splash_gradient_background"
    android:fitsSystemWindows="true">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Join Class"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        android:layout_marginBottom="24dp">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            app:boxStrokeColor="@color/splash_accent"
            app:hintTextColor="@color/splash_accent"
            app:startIconDrawable="@android:drawable/ic_menu_search"
            app:startIconTint="@color/splash_accent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_class_code"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter Class Code (e.g. ABC123)"
                android:inputType="textCapCharacters"
                android:textSize="18sp"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

    </com.google.android.material.card.MaterialCardView>

    <ProgressBar
        android:id="@+id/progress_bar"
        style="@android:style/Widget.ProgressBar.Large"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp"
        android:visibility="gone" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_join_class"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Join Class"
        android:textSize="16sp"
        android:textStyle="bold"
        android:enabled="false"
        app:cornerRadius="28dp"
        app:backgroundTint="@color/splash_accent"
        app:strokeColor="@color/splash_accent"
        app:strokeWidth="2dp"
        style="@style/Widget.Material3.Button.OutlinedButton" />

</LinearLayout>
