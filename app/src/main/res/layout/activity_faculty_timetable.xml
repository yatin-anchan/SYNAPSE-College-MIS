<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_background"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/splash_card_background"
        app:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/splash_card_background"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/white"
            app:subtitleTextColor="@color/splash_text_secondary"
            app:titleTextColor="@color/splash_text_primary" />

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/splash_card_background"
            app:tabIndicatorColor="@color/splash_primary"
            app:tabIndicatorHeight="3dp"
            app:tabMode="fixed"
            app:tabGravity="fill"
            app:tabSelectedTextColor="@color/splash_text_primary"
            app:tabTextColor="@color/splash_text_secondary" />
    </com.google.android.material.appbar.AppBarLayout>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ══ TAB 0 — TODAY ══ -->
            <LinearLayout
                android:id="@+id/layout_tab_today"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_today_heading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="Today"
                    android:textColor="@color/splash_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Summary mini card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_today_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/splash_card_background"
                    app:cardCornerRadius="14dp"
                    app:strokeColor="@color/splash_primary"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="14dp"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Lectures"
                                android:textColor="@color/splash_text_secondary"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tv_today_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/splash_primary"
                                android:textSize="20sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Teaching Time"
                                android:textColor="@color/splash_text_secondary"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tv_today_hours"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0h 0m"
                                android:textColor="@color/splash_success"
                                android:textSize="20sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_today"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

                <TextView
                    android:id="@+id/tv_empty_today"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:gravity="center"
                    android:text="🎉 No classes assigned today"
                    android:textColor="@color/splash_text_secondary"
                    android:textSize="15sp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- ══ TAB 1 — WEEKLY ══ -->
            <LinearLayout
                android:id="@+id/layout_tab_weekly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/day_tabs_weekly"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginBottom="14dp"
                    android:background="@color/splash_card_background"
                    app:tabIndicatorColor="@color/splash_primary"
                    app:tabIndicatorHeight="2dp"
                    app:tabMode="scrollable"
                    app:tabSelectedTextColor="@color/splash_text_primary"
                    app:tabTextColor="@color/splash_text_secondary" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_weekly"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

                <TextView
                    android:id="@+id/tv_empty_weekly"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:gravity="center"
                    android:text="No classes on this day"
                    android:textColor="@color/splash_text_secondary"
                    android:textSize="15sp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- ══ TAB 2 — SUMMARY ══ -->
            <LinearLayout
                android:id="@+id/layout_tab_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Stats row -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="@color/splash_card_background"
                    app:cardCornerRadius="16dp"
                    app:strokeColor="@color/splash_card_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:weightSum="3">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Subjects" android:textColor="@color/splash_text_secondary" android:textSize="11sp" />
                            <TextView android:id="@+id/tv_subject_count"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0" android:textColor="@color/splash_info"
                                android:textSize="22sp" android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Total/Week" android:textColor="@color/splash_text_secondary" android:textSize="11sp" />
                            <TextView android:id="@+id/tv_total_weekly"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0" android:textColor="@color/splash_primary"
                                android:textSize="22sp" android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Hours/Week" android:textColor="@color/splash_text_secondary" android:textSize="11sp" />
                            <TextView android:id="@+id/tv_total_hours"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0h" android:textColor="@color/splash_success"
                                android:textSize="22sp" android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>