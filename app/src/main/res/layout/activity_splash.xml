<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_gradient_background"
    android:gravity="center">

    <!-- Star decorations - More visible and spread out -->
    <ImageView
        android:id="@+id/star1"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="100dp"
        android:layout_marginEnd="60dp"
        android:src="@drawable/ic_star"
        android:alpha="0"
        android:contentDescription="@string/decorative_star" />

    <ImageView
        android:id="@+id/star2"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:layout_marginTop="150dp"
        android:layout_marginStart="40dp"
        android:src="@drawable/ic_star"
        android:alpha="0"
        android:contentDescription="@string/decorative_star" />

    <ImageView
        android:id="@+id/star3"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="120dp"
        android:src="@drawable/ic_star"
        android:alpha="0"
        android:contentDescription="@string/decorative_star" />

    <ImageView
        android:id="@+id/star4"
        android:layout_width="11dp"
        android:layout_height="11dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="30dp"
        android:src="@drawable/ic_star"
        android:alpha="0"
        android:contentDescription="@string/decorative_star" />

    <ImageView
        android:id="@+id/star5"
        android:layout_width="9dp"
        android:layout_height="9dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:layout_marginStart="50dp"
        android:layout_marginTop="-80dp"
        android:src="@drawable/ic_star"
        android:alpha="0"
        android:contentDescription="@string/decorative_star" />

    <ImageView
        android:id="@+id/star6"
        android:layout_width="13dp"
        android:layout_height="13dp"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginStart="100dp"
        android:layout_marginTop="200dp"
        android:src="@drawable/ic_star"
        android:alpha="0"
        android:contentDescription="@string/decorative_star" />

    <ImageView
        android:id="@+id/star7"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:layout_marginTop="250dp"
        android:layout_marginEnd="100dp"
        android:src="@drawable/ic_star"
        android:alpha="0"
        android:contentDescription="@string/decorative_star" />

    <ImageView
        android:id="@+id/star8"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:layout_marginStart="80dp"
        android:layout_marginBottom="200dp"
        android:src="@drawable/ic_star"
        android:alpha="0"
        android:contentDescription="@string/decorative_star" />

    <ImageView
        android:id="@+id/star9"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="70dp"
        android:layout_marginBottom="250dp"
        android:src="@drawable/ic_star"
        android:alpha="0"
        android:contentDescription="@string/decorative_star" />

    <ImageView
        android:id="@+id/star10"
        android:layout_width="11dp"
        android:layout_height="11dp"
        android:layout_centerHorizontal="true"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="300dp"
        android:layout_marginStart="-120dp"
        android:src="@drawable/ic_star"
        android:alpha="0"
        android:contentDescription="@string/decorative_star" />

    <!-- Main content container -->
    <LinearLayout
        android:id="@+id/main_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical"
        android:alpha="0">

        <!-- App Logo/Icon with glow effect -->
        <ImageView
            android:id="@+id/app_logo"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:contentDescription="@string/app_logo"
            android:src="@drawable/ic_synapse_logo"
            android:elevation="8dp" />

        <!-- App Name with shadow -->
        <TextView
            android:id="@+id/app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/app_name_synapse"
            android:textColor="@color/splash_text_color"
            android:textSize="48sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:letterSpacing="0.08"
            android:shadowColor="#6C63FF"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="20" />

        <!-- Tagline with better visibility -->
        <TextView
            android:id="@+id/app_tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/app_tagline"
            android:textColor="@color/splash_text_secondary"
            android:textSize="16sp"
            android:letterSpacing="0.15"
            android:alpha="0.95" />

    </LinearLayout>

    <!-- Bottom branding -->
    <LinearLayout
        android:id="@+id/bottom_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="56dp"
        android:gravity="center"
        android:orientation="vertical"
        android:alpha="0">

        <!-- College/Institution badge with elevation -->
        <ImageView
            android:id="@+id/institution_badge"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_institution_badge"
            android:contentDescription="@string/institution_badge"
            android:elevation="4dp" />

        <!-- Powered by text with better visibility -->
        <TextView
            android:id="@+id/powered_by"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/powered_by_text"
            android:textColor="@color/splash_text_secondary"
            android:textSize="13sp"
            android:letterSpacing="0.1"
            android:alpha="0.85" />

    </LinearLayout>

    <!-- Loading indicator with better visibility -->
    <ProgressBar
        android:id="@+id/loading_indicator"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="140dp"
        android:indeterminateTint="@color/splash_accent"
        android:alpha="0" />

</RelativeLayout>