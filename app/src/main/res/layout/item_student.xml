<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="#40FFFFFF"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Profile Image -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/profile_image"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_person"
            app:civ_border_width="2dp"
            app:civ_border_color="@color/splash_accent"/>

        <!-- Student Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <!-- Name and Status -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/student_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Student Name"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/status_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:text="Active"
                    android:textSize="10sp"
                    app:chipMinHeight="24dp"
                    app:chipBackgroundColor="@android:color/holo_green_dark"
                    android:textColor="@color/white"/>
            </LinearLayout>

            <!-- Student ID and Roll Number -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/student_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="STU2024001"
                    android:textColor="@color/splash_text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="monospace"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • "
                    android:textColor="@color/splash_text_secondary"
                    android:textSize="12sp"/>

                <TextView
                    android:id="@+id/roll_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Roll: 101"
                    android:textColor="@color/splash_text_secondary"
                    android:textSize="12sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • "
                    android:textColor="@color/splash_text_secondary"
                    android:textSize="12sp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/gender_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:text="Male"
                    android:textSize="9sp"
                    app:chipMinHeight="20dp"
                    app:chipBackgroundColor="@android:color/holo_blue_light"
                    android:textColor="@color/white"/>
            </LinearLayout>

            <!-- Email -->
            <TextView
                android:id="@+id/email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="student@example.com"
                android:textColor="@color/splash_text_color"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:drawableStart="@drawable/ic_email"
                android:drawablePadding="4dp"
                android:drawableTint="@color/splash_accent"/>

            <!-- Department and Class -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/department"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Computer Science"
                    android:textColor="@color/splash_text_color"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:drawableStart="@drawable/ic_departments"
                    android:drawablePadding="4dp"
                    android:drawableTint="@color/splash_text_secondary"/>

                <TextView
                    android:id="@+id/class_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="FY BSc CS"
                    android:textColor="@color/splash_text_color"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:drawableStart="@drawable/ic_class"
                    android:drawablePadding="4dp"
                    android:drawableTint="@color/splash_text_secondary"/>
            </LinearLayout>

            <!-- Performance Stats -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                android:paddingTop="8dp"
                android:background="@drawable/top_border">

                <TextView
                    android:id="@+id/attendance_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="85.5%"
                    android:textColor="@color/splash_accent"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:drawableStart="@drawable/ic_attendance"
                    android:drawablePadding="4dp"
                    android:drawableTint="@color/splash_accent"/>

                <TextView
                    android:id="@+id/cgpa_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="8.5"
                    android:textColor="@color/splash_accent"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:gravity="end"
                    android:drawableEnd="@drawable/ic_grade"
                    android:drawablePadding="4dp"
                    android:drawableTint="@color/splash_accent"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
