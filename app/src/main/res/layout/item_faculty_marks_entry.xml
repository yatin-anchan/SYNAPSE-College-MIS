<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#331A1A3E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_glass_effect"
        android:padding="14dp">

        <!-- Top Row: Roll No + Student Name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/rollno"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A001"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="#334FACFE"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/studentname"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Student Name"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginStart="10dp"
                android:singleLine="true"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Middle Row: Written + Internal Marks Inputs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <!-- Written Marks Input -->
            <LinearLayout
                android:id="@+id/written_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Written"
                    app:boxStrokeColor="#44FFFFFF"
                    app:boxBackgroundColor="#22FFFFFF"
                    app:hintTextColor="#55FFFFFF">

                    <!-- FIX: must be TextInputEditText inside TextInputLayout -->
                    <!-- plain EditText causes the layout to intercept touches  -->
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/writteninput"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@null"
                        android:gravity="center"
                        android:hint="0"
                        android:inputType="numberDecimal"
                        android:textAlignment="center"
                        android:textColor="@android:color/white"
                        android:textColorHint="#55FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/written_max_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="/ 70"
                    android:textColor="#66FFFFFF"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

            <!-- Divider (only visible when both columns shown) -->
            <View
                android:id="@+id/columns_divider"
                android:layout_width="1dp"
                android:layout_height="50dp"
                android:background="#44FFFFFF"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp" />

            <!-- Internal Marks Input -->
            <LinearLayout
                android:id="@+id/internal_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Internal"
                    app:boxStrokeColor="#44FFFFFF"
                    app:boxBackgroundColor="#22FFFFFF"
                    app:hintTextColor="#55FFFFFF">

                    <!-- FIX: must be TextInputEditText inside TextInputLayout -->
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/internalinput"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@null"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textAlignment="center"
                        android:inputType="numberDecimal"
                        android:hint="0"
                        android:textColorHint="#55FFFFFF"
                        android:gravity="center" />

                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/internal_max_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="/ 30"
                    android:textColor="#66FFFFFF"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Total Max Marks -->
        <TextView
            android:id="@+id/maxmarkstext"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Total: 100"
            android:textColor="#88FFFFFF"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <!-- Bottom Row: Absent + Percentage + Grade -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <CheckBox
                    android:id="@+id/absentcheckbox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@android:color/holo_red_light"
                    android:text="Absent"
                    android:textColor="#88FFFFFF"
                    android:textSize="12sp" />

            </LinearLayout>

            <TextView
                android:id="@+id/percentagetext"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-"
                android:textColor="#88FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/gradetext"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"
                android:text="-"
                android:textColor="#88FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textAlignment="center" />

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>