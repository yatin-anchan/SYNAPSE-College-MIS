<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_background"
    android:fitsSystemWindows="true">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/splash_card_background">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/splash_card_background"
            app:titleTextColor="@color/splash_text_primary"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/white"/>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Filter Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/splash_card_background"
                app:strokeWidth="1dp"
                app:strokeColor="@color/splash_card_stroke">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Defaulter Criteria"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/splash_text_primary"
                        android:layout_marginBottom="12dp"/>

                    <Spinner
                        android:id="@+id/spinnerClassDefaulter"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/spinner_background"
                        android:layout_marginBottom="12dp"/>

                    <!-- Start Date -->
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etStartDate"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Start Date"
                        android:focusable="false"
                        android:clickable="true"
                        android:background="@drawable/rounded_background_transparent"
                        android:padding="12dp"
                        android:layout_marginBottom="8dp"/>

                    <!-- End Date -->
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etEndDate"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="End Date"
                        android:focusable="false"
                        android:clickable="true"
                        android:background="@drawable/rounded_background_transparent"
                        android:padding="12dp"
                        android:layout_marginBottom="8dp"/>

                    <!-- Threshold -->
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etThreshold"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="Attendance Threshold (%)"
                        android:inputType="number"
                        android:background="@drawable/card_glass_effect"
                        android:padding="12dp"
                        android:layout_marginBottom="16dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGenerateDefaulter"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="🚨 Generate Defaulter List"
                        android:textStyle="bold"
                        app:cornerRadius="12dp"
                        app:backgroundTint="@color/splash_error"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Summary -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDefaulterSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/splash_card_background">

                <TextView
                    android:id="@+id/tvDefaulterSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:textColor="@color/splash_text_primary"
                    android:textSize="14sp"/>
            </com.google.android.material.card.MaterialCardView>

            <!-- Recycler -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDefaulters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"/>

            <!-- Empty -->
            <TextView
                android:id="@+id/tvEmptyDefaulter"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:gravity="center"
                android:text="No defaulters found"
                android:textColor="@color/splash_text_secondary"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Progress -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progressBarDefaulter"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:visibility="gone"
        app:indicatorColor="@color/splash_primary"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>