<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_gradient_background"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:fitsSystemWindows="true"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/toolbar_gradient"
            app:titleTextColor="@android:color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Timetable Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#331A1A3E">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_glass_effect"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:src="@android:drawable/ic_menu_agenda"
                            app:tint="@color/white"
                            android:padding="10dp"
                            android:background="@drawable/circle_gradient" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">

                            <TextView
                                android:id="@+id/tv_class_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Class A"
                                android:textColor="@android:color/white"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:shadowColor="#667EEA"
                                android:shadowRadius="8" />

                            <TextView
                                android:id="@+id/tv_dept_course"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Department • Course"
                                android:textColor="@android:color/white"
                                android:textSize="12sp"
                                android:alpha="0.7"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <!-- View-only badge -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VIEW ONLY"
                            android:textColor="@android:color/white"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:background="@drawable/bg_chip_theory"
                            android:alpha="0.8" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#22FFFFFF"
                        android:layout_marginBottom="12dp" />

                    <!-- Stats row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_exams"
                                app:tint="#667EEA"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tv_semester_year"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sem 1 | 2024-25"
                                android:textColor="@android:color/white"
                                android:textSize="11sp"
                                android:textAlignment="center"
                                android:alpha="0.85" />

                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="36dp"
                            android:background="#22FFFFFF" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/ic_menu_recent_history"
                                app:tint="#4FACFE"
                                android:layout_marginBottom="4dp" />

                            <TextView
                                android:id="@+id/tv_default_duration"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="60 min/lecture"
                                android:textColor="@android:color/white"
                                android:textSize="11sp"
                                android:textAlignment="center"
                                android:alpha="0.85" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- PDF + Share buttons (HOD can download/share but not edit) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_generate_pdf"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Download PDF"
                    android:textSize="14sp"
                    android:padding="13dp"
                    app:icon="@drawable/ic_draft"
                    app:iconGravity="textStart"
                    app:backgroundTint="#4FACFE"
                    android:textColor="@android:color/white"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_share"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Share"
                    android:textSize="14sp"
                    android:padding="13dp"
                    app:icon="@drawable/ic_arrow_forward"
                    app:iconGravity="textStart"
                    app:backgroundTint="#6C63FF"
                    android:textColor="@android:color/white"
                    app:cornerRadius="12dp" />

            </LinearLayout>

            <!-- Day Selector Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#401A1A3E">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Row: label + today badge + selected day -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_calendar"
                            app:tint="#4FACFE"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Select Day"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:alpha="0.9" />

                        <!-- "TODAY" green badge - shown only when viewing today -->
                        <TextView
                            android:id="@+id/tv_today_badge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TODAY"
                            android:textColor="@android:color/white"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"
                            android:background="@drawable/bg_chip_practical"
                            android:layout_marginEnd="8dp"
                            android:visibility="visible" />

                        <TextView
                            android:id="@+id/tv_selected_day"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Monday"
                            android:textColor="#667EEA"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Day radio buttons -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">

                        <RadioGroup
                            android:id="@+id/rg_days"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal" />

                    </HorizontalScrollView>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Schedule section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Schedule"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="60dp"
                    android:layout_height="2dp"
                    android:background="#22FFFFFF" />

            </LinearLayout>

            <!-- Slots (read-only, reuses same SlotsAdapter with readOnly=true) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_slots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false" />

            <!-- Empty day state -->
            <LinearLayout
                android:id="@+id/tv_empty_day"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone">

                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@android:drawable/ic_menu_agenda"
                    app:tint="@color/splash_text_secondary"
                    android:alpha="0.4"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No lectures scheduled for this day"
                    android:textColor="@color/splash_text_secondary"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:alpha="0.7" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="24dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/splash_accent"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>