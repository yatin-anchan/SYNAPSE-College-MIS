<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_glass_effect"
    android:padding="20dp">

    <!-- Subject Info Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_edit"
            app:tint="@color/splash_accent"
            android:padding="8dp"
            android:background="@drawable/circle_gradient" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit Subject Details"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <!-- Exam Date -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Exam Date"
        android:textSize="12sp"
        android:textColor="@color/splash_text_secondary"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#22FFFFFF"
        android:padding="12dp"
        android:layout_marginBottom="16dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_calendar"
            app:tint="@color/splash_accent" />

        <TextView
            android:id="@+id/exam_date_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Not Selected"
            android:textSize="16sp"
            android:textColor="@android:color/white"
            android:layout_marginStart="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_select_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Change"
            android:textSize="12sp"
            app:icon="@drawable/ic_edit"
            app:backgroundTint="@color/splash_accent" />
    </LinearLayout>

    <!-- Duration -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Duration (hours)"
        app:boxBackgroundColor="#22FFFFFF"
        app:boxStrokeColor="@color/splash_accent"
        app:hintTextColor="@color/splash_accent"
        app:startIconDrawable="@drawable/ic_time"
        app:startIconTint="@color/splash_accent"
        android:layout_marginBottom="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/duration_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:inputType="numberDecimal" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Start Time -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Start Time"
        app:boxBackgroundColor="#22FFFFFF"
        app:boxStrokeColor="@color/splash_accent"
        app:hintTextColor="@color/splash_accent"
        app:startIconDrawable="@drawable/ic_time"
        app:startIconTint="@color/splash_accent"
        android:layout_marginBottom="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/start_time_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:focusable="false"
            android:clickable="true"
            android:inputType="none" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- End Time -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="End Time"
        app:boxBackgroundColor="#22FFFFFF"
        app:boxStrokeColor="@color/splash_accent"
        app:hintTextColor="@color/splash_accent"
        app:startIconDrawable="@drawable/ic_time"
        app:startIconTint="@color/splash_accent"
        android:layout_marginBottom="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/end_time_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:focusable="false"
            android:clickable="true"
            android:inputType="none" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Max Marks -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Max Marks"
        app:boxBackgroundColor="#22FFFFFF"
        app:boxStrokeColor="@color/splash_accent"
        app:hintTextColor="@color/splash_accent"
        app:startIconDrawable="@drawable/ic_grade"
        app:startIconTint="@color/splash_accent">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/max_marks_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:inputType="number" />
    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>
