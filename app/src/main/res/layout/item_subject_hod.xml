<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="#401A1A3E"
    app:strokeColor="#FF667EEA"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Subject Name & Code -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/subject_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Data Structures &amp; Algorithms"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/subject_code"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CS301"
                android:textColor="#ffff"
                android:textSize="16sp"
                android:background="@drawable/subject_code_bg"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp" />

        </LinearLayout>

        <!-- Details -->
        <TextView
            android:id="@+id/subject_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Theory • Sem 5 • 4cr"
            android:textColor="#B0FFFFFF"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp" />

        <!-- Faculty -->
        <TextView
            android:id="@+id/subject_faculty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👤 Dr. Rahul Sharma"
            android:textColor="@color/green_500"
            android:textSize="15sp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
