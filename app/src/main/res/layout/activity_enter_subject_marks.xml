<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/splash_gradient_background">

    <!-- ══ AppBar ══ -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/toolbar_gradient"
            app:titleTextColor="@android:color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ══ Main content ══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- ── Subject / Marks-scheme info card ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#331A1A3E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_glass_effect"
                android:padding="20dp">

                <!-- Subject name -->
                <TextView
                    android:id="@+id/subject_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Subject Name"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Exam-type chip  -->
                <TextView
                    android:id="@+id/exam_type_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="26dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/badge_accepted"
                    android:gravity="center"
                    android:paddingHorizontal="12dp"
                    android:text="Written"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <!-- Marks scheme breakdown: "Written: 70  |  Internal: 30  |  Total: 100" -->
                <TextView
                    android:id="@+id/marks_scheme_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Total: 100"
                    android:textColor="@color/splash_text_color"
                    android:textSize="13sp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="10dp"
                    android:background="#22FFFFFF" />

                <!-- Student count -->
                <TextView
                    android:id="@+id/students_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 Students"
                    android:textColor="@color/splash_text_color"
                    android:textSize="14sp"
                    android:drawableStart="@drawable/ic_person"
                    android:drawablePadding="6dp"
                    android:drawableTint="@color/splash_accent" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── Students list ── -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp"
            android:clipToPadding="false" />

        <!-- ── Save button ── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save_all"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_margin="16dp"
            android:text="Save All Marks"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            app:icon="@drawable/ic_check_circle"
            app:iconGravity="textStart"
            app:iconSize="24dp"
            app:backgroundTint="@android:color/holo_green_dark" />

    </LinearLayout>

    <!-- ── Loading spinner (centred over everything) ── -->
    <ProgressBar
        android:id="@+id/loading_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>