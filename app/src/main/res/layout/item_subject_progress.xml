<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/splash_card_background"
    app:cardCornerRadius="16dp"
    app:cardElevation="5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Row 1: Subject Name + Status Chip -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_subject_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/splash_text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="2"
                    android:ellipsize="end"
                    tools:text="Mathematics - III" />

                <TextView
                    android:id="@+id/tv_subject_code"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/splash_text_secondary"
                    android:textSize="12sp"
                    tools:text="BS-301" />

            </LinearLayout>

            <!-- Status Chip -->
            <TextView
                android:id="@+id/tv_status_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/card_glass_effect"
                android:paddingStart="10dp"
                android:paddingTop="4dp"
                android:paddingEnd="10dp"
                android:paddingBottom="4dp"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="In Progress" />

        </LinearLayout>

        <!-- Thin divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:background="#1AFFFFFF" />

        <!-- Row 2: Marks text + Absent badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="7dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_edit"
                app:tint="@color/splash_text_secondary"
                android:layout_marginEnd="6dp" />

            <TextView
                android:id="@+id/tv_progress_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/splash_text_secondary"
                android:textSize="12sp"
                tools:text="42/60 marks entered" />

            <TextView
                android:id="@+id/tv_absent_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FF5252"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"
                android:visibility="gone"
                tools:text="• 3 absent"
                tools:visibility="visible" />

        </LinearLayout>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progress_bar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="7dp"
            android:max="100"
            android:progressDrawable="@drawable/progress_bar_track"
            tools:progress="70" />

        <!-- Stepper Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="14dp">

            <!-- Step 1: Entered -->
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="center_horizontal">
                <FrameLayout android:layout_width="22dp" android:layout_height="22dp">
                    <View android:layout_width="22dp" android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:background="@drawable/stepper_dot_inactive" />
                    <View android:id="@+id/dot_1_fill"
                        android:layout_width="22dp" android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:background="@drawable/stepper_dot_active"
                        android:visibility="gone" />
                </FrameLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="3dp" android:textSize="9sp"
                    android:textColor="@color/splash_text_secondary"
                    android:text="Entered" android:gravity="center" />
            </LinearLayout>

            <View android:id="@+id/line_12"
                android:layout_width="0dp" android:layout_height="3dp"
                android:layout_weight="1" android:layout_marginBottom="13dp"
                android:background="@drawable/stepper_line_inactive" />

            <!-- Step 2: Submitted -->
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="center_horizontal">
                <FrameLayout android:layout_width="22dp" android:layout_height="22dp">
                    <View android:layout_width="22dp" android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:background="@drawable/stepper_dot_inactive" />
                    <View android:id="@+id/dot_2_fill"
                        android:layout_width="22dp" android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:background="@drawable/stepper_dot_active"
                        android:visibility="gone" />
                </FrameLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="3dp" android:textSize="9sp"
                    android:textColor="@color/splash_text_secondary"
                    android:text="Submitted" android:gravity="center" />
            </LinearLayout>

            <View android:id="@+id/line_23"
                android:layout_width="0dp" android:layout_height="3dp"
                android:layout_weight="1" android:layout_marginBottom="13dp"
                android:background="@drawable/stepper_line_inactive" />

            <!-- Step 3: Moderated -->
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="center_horizontal">
                <FrameLayout android:layout_width="22dp" android:layout_height="22dp">
                    <View android:layout_width="22dp" android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:background="@drawable/stepper_dot_inactive" />
                    <View android:id="@+id/dot_3_fill"
                        android:layout_width="22dp" android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:background="@drawable/stepper_dot_active"
                        android:visibility="gone" />
                </FrameLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="3dp" android:textSize="9sp"
                    android:textColor="@color/splash_text_secondary"
                    android:text="Moderated" android:gravity="center" />
            </LinearLayout>

            <View android:id="@+id/line_34"
                android:layout_width="0dp" android:layout_height="3dp"
                android:layout_weight="1" android:layout_marginBottom="13dp"
                android:background="@drawable/stepper_line_inactive" />

            <!-- Step 4: Published -->
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="vertical" android:gravity="center_horizontal">
                <FrameLayout android:layout_width="22dp" android:layout_height="22dp">
                    <View android:layout_width="22dp" android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:background="@drawable/stepper_dot_inactive" />
                    <View android:id="@+id/dot_4_fill"
                        android:layout_width="22dp" android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:background="@drawable/stepper_dot_active"
                        android:visibility="gone" />
                </FrameLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="3dp" android:textSize="9sp"
                    android:textColor="@color/splash_text_secondary"
                    android:text="Published" android:gravity="center" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>