<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_background"
    tools:context=".AttendanceDraftDetailsActivity"
    android:fitsSystemWindows="true">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/splash_card_background"
        app:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/splash_card_background"
            app:titleTextColor="@color/splash_text_primary"
            app:subtitleTextColor="@color/splash_text_secondary"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/white" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Session Details Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_details"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/splash_card_background"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/splash_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Session Details"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/splash_text_primary"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="12dp" />

                    <!-- Class Name -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_class"
                            app:tint="@color/splash_primary" />

                        <TextView
                            android:id="@+id/tv_class_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:textSize="14sp"
                            android:textColor="@color/splash_text_primary"
                            tools:text="CSE 3rd Year A" />

                    </LinearLayout>

                    <!-- Subject Name -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_book"
                            app:tint="@color/neural_cyan" />

                        <TextView
                            android:id="@+id/tv_subject_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:textSize="14sp"
                            android:textColor="@color/splash_text_primary"
                            tools:text="Data Structures" />

                    </LinearLayout>

                    <!-- Date -->
                    <TextView
                        android:id="@+id/tv_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/splash_text_secondary"
                        android:layout_marginBottom="4dp"
                        tools:text="Date: 15/01/2025" />

                    <!-- Time -->
                    <TextView
                        android:id="@+id/tv_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/splash_text_secondary"
                        android:layout_marginBottom="4dp"
                        tools:text="Time: 10:00 AM - 11:00 AM" />

                    <!-- Duration -->
                    <TextView
                        android:id="@+id/tv_duration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/splash_text_secondary"
                        tools:text="Duration: 60 mins" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Attendance Summary Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/splash_card_background"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/splash_card_stroke"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Attendance Summary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/splash_text_primary"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="12dp" />

                    <!-- Summary Grid -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="4">

                        <!-- Total Students -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total"
                                android:textSize="12sp"
                                android:textColor="@color/splash_text_secondary" />

                            <TextView
                                android:id="@+id/tv_total_students"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="@color/splash_info"
                                tools:text="50" />

                        </LinearLayout>

                        <!-- Present Count -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Present"
                                android:textSize="12sp"
                                android:textColor="@color/splash_text_secondary" />

                            <TextView
                                android:id="@+id/tv_present_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="@color/splash_success"
                                tools:text="45" />

                        </LinearLayout>

                        <!-- Absent Count -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Absent"
                                android:textSize="12sp"
                                android:textColor="@color/splash_text_secondary" />

                            <TextView
                                android:id="@+id/tv_absent_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="@color/splash_error"
                                tools:text="5" />

                        </LinearLayout>

                        <!-- Percentage -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Rate"
                                android:textSize="12sp"
                                android:textColor="@color/splash_text_secondary" />

                            <TextView
                                android:id="@+id/tv_percentage"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="@color/splash_primary"
                                tools:text="90%" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Student List Header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Student Attendance"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/splash_text_primary"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="12dp" />

            <!-- RecyclerView for Students -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:layout_marginBottom="100dp"
                tools:listitem="@layout/item_draft_student_attendance" />

            <!-- Loading Progress -->
            <ProgressBar
                android:id="@+id/loading_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="48dp"
                android:indeterminateTint="@color/splash_primary"
                android:visibility="gone" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@color/splash_card_background"
        android:elevation="8dp"
        android:padding="16dp">

        <!-- Slide to Confirm -->
        <com.projectbyyatin.synapsemis.views.SlideToConfirmView
            android:id="@+id/slide_to_confirm"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            app:slideText="Slide to Publish"
            app:slideCompletedText="✓ Published"
            app:slideThreshold="0.85"
            app:slideBackgroundColor="@color/splash_card_background"
            app:slideProgressColor="@color/splash_primary"
            app:slideThumbColor="@color/white"
            app:slideTextColor="@color/splash_text_primary"
            app:slideCompletedColor="@color/splash_success"
            app:slideTextSize="16sp" />

        <!-- Cancel Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Cancel"
            android:textSize="16sp"
            android:textColor="@color/splash_text_primary"
            app:backgroundTint="@color/transparent"
            app:strokeColor="@color/splash_border"
            app:strokeWidth="2dp"
            app:cornerRadius="12dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>