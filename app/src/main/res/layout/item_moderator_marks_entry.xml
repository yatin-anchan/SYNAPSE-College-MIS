<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#331A1A3E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_glass_effect"
        android:padding="14dp">

        <!-- Top Row: Roll No + Name + Modified Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <!-- Roll No Badge -->
            <TextView
                android:id="@+id/roll_no"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A001"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="#334FACFE"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/student_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Student Name"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginStart="10dp"
                android:singleLine="true"
                android:ellipsize="end" />

            <!-- Modified Badge dot -->
            <View
                android:id="@+id/modified_badge"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="#FF6C63FF"
                android:visibility="gone"
                android:layout_marginEnd="6dp" />

            <!-- Original marks (if moderated) -->
            <TextView
                android:id="@+id/original_marks_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Original: 45"
                android:textColor="#FFB347"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Bottom Row: Marks Input + Absent + Percentage + Grade -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Marks Input + Max -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.4"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/marks_input"
                    android:layout_width="72dp"
                    android:layout_height="44dp"
                    android:background="#22FFFFFF"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAlignment="center"
                    android:inputType="numberDecimal"
                    android:hint="--"
                    android:textColorHint="#55FFFFFF"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp" />

                <TextView
                    android:id="@+id/max_marks_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="/ 100"
                    android:textColor="#88FFFFFF"
                    android:textSize="13sp"
                    android:layout_marginStart="6dp" />
            </LinearLayout>

            <!-- Absent Checkbox -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <CheckBox
                    android:id="@+id/absent_checkbox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@android:color/holo_red_light"
                    android:text="Absent"
                    android:textColor="#88FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Percentage -->
            <TextView
                android:id="@+id/percentage_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.8"
                android:text="-"
                android:textColor="#88FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAlignment="center" />

            <!-- Grade -->
            <TextView
                android:id="@+id/grade_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.6"
                android:text="-"
                android:textColor="#88FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAlignment="center" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>