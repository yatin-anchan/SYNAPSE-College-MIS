<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#331A1A3E"
    app:strokeColor="@color/splash_card_stroke"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@drawable/card_glass_effect"
        android:gravity="center_vertical">

        <!-- Student Info Section -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="12dp">

            <!-- Student Name -->
            <TextView
                android:id="@+id/tv_student_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/splash_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:ellipsize="end"
                android:maxLines="1"
                tools:text="Rahul Kumar Sharma" />

            <!-- Roll Number -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_students"
                    app:tint="@color/splash_text_secondary"
                    android:alpha="0.8" />

                <TextView
                    android:id="@+id/tv_roll_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:textColor="@color/splash_text_secondary"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"
                    tools:text="Roll: 2021CSE042" />

            </LinearLayout>

        </LinearLayout>

        <!-- Attendance Chips Section -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <!-- Present Chip -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_present"
                android:layout_width="100dp"
                android:layout_height="36dp"
                android:layout_marginBottom="6dp"
                android:checkable="true"
                android:clickable="true"
                android:focusable="true"
                android:text="Present"
                android:textColor="@color/splash_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                app:chipBackgroundColor="@color/chip_unselected"
                app:chipCornerRadius="12dp"
                app:chipIcon="@drawable/ic_check"
                app:chipIconSize="16dp"
                app:chipIconTint="@color/white"
                app:chipMinHeight="36dp"
                app:chipStrokeColor="@color/splash_success"
                app:chipStrokeWidth="2dp"
                app:ensureMinTouchTargetSize="false"
                app:rippleColor="@color/splash_success" />

            <!-- Absent Chip -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_absent"
                android:layout_width="100dp"
                android:layout_height="36dp"
                android:checkable="true"
                android:clickable="true"
                android:focusable="true"
                android:text="Absent"
                android:textColor="@color/splash_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                app:chipBackgroundColor="@color/chip_unselected"
                app:chipCornerRadius="12dp"
                app:chipIcon="@drawable/ic_close"
                app:chipIconSize="16dp"
                app:chipIconTint="@color/white"
                app:chipMinHeight="36dp"
                app:chipStrokeColor="@color/splash_error"
                app:chipStrokeWidth="2dp"
                app:ensureMinTouchTargetSize="false"
                app:rippleColor="@color/splash_error" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>