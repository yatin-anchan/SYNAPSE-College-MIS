<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/splash_gradient_background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/toolbar_gradient"
            app:titleTextColor="@android:color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:fitsSystemWindows="true"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#331A1A3E">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_glass_effect"
                    android:padding="16dp"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:src="@drawable/ic_class"
                        app:tint="@color/white"
                        android:padding="16dp"
                        android:background="@drawable/circle_gradient" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Create New Class"
                        android:textColor="@android:color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fill in the details below to create a new class"
                        android:textColor="@color/splash_text_secondary"
                        android:textSize="13sp"
                        android:textAlignment="center"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Form Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fitsSystemWindows="true"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#331A1A3E">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_glass_effect"
                    android:padding="20dp">

                    <!-- Class Name -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Class Name"
                        app:boxBackgroundColor="#22FFFFFF"
                        app:boxStrokeColor="@color/splash_accent"
                        app:hintTextColor="@color/splash_accent"
                        app:startIconDrawable="@drawable/ic_class"
                        app:startIconTint="@color/splash_accent"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/class_name_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@android:color/white"
                            android:inputType="textCapWords" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Course Selection -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Select Course"
                        app:boxBackgroundColor="#22FFFFFF"
                        app:boxStrokeColor="@color/splash_accent"
                        app:hintTextColor="@color/splash_accent"
                        app:startIconDrawable="@drawable/ic_book"
                        app:startIconTint="@color/splash_accent"
                        android:layout_marginBottom="16dp">

                        <AutoCompleteTextView
                            android:id="@+id/course_dropdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@android:color/white"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Class Teacher Selection -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Select Class Teacher"
                        app:boxBackgroundColor="#22FFFFFF"
                        app:boxStrokeColor="@color/splash_accent"
                        app:hintTextColor="@color/splash_accent"
                        app:startIconDrawable="@drawable/ic_person"
                        app:startIconTint="@color/splash_accent"
                        android:layout_marginBottom="16dp">

                        <AutoCompleteTextView
                            android:id="@+id/class_teacher_dropdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@android:color/white"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#22FFFFFF"
                        android:layout_marginVertical="8dp" />

                    <!-- First Row: Current Semester and Total Semesters -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <!-- Current Semester -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Current Semester"
                            app:boxBackgroundColor="#22FFFFFF"
                            app:boxStrokeColor="@color/splash_accent"
                            app:hintTextColor="@color/splash_accent"
                            app:startIconDrawable="@drawable/ic_book"
                            app:startIconTint="@color/splash_accent"
                            android:layout_marginEnd="8dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/current_semester_input"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@android:color/white"
                                android:inputType="number"
                                android:text="1" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Total Semesters -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Total Semesters"
                            app:boxBackgroundColor="#22FFFFFF"
                            app:boxStrokeColor="@color/splash_accent"
                            app:hintTextColor="@color/splash_accent"
                            app:startIconDrawable="@drawable/ic_book"
                            app:startIconTint="@color/splash_accent"
                            android:layout_marginStart="8dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/total_semesters_input"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@android:color/white"
                                android:inputType="number"
                                android:text="6" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Second Row: Max Size and Batch -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp">

                        <!-- Max Size -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Max Size"
                            app:boxBackgroundColor="#22FFFFFF"
                            app:boxStrokeColor="@color/splash_accent"
                            app:hintTextColor="@color/splash_accent"
                            app:startIconDrawable="@drawable/ic_person"
                            app:startIconTint="@color/splash_accent"
                            android:layout_marginEnd="8dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/max_size_input"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@android:color/white"
                                android:inputType="number"
                                android:text="60" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Batch (Auto-calculated) -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Batch"
                            app:boxBackgroundColor="#22FFFFFF"
                            app:boxStrokeColor="@color/splash_accent"
                            app:hintTextColor="@color/splash_accent"
                            app:startIconDrawable="@drawable/ic_calendar"
                            app:startIconTint="@color/splash_accent"
                            android:layout_marginStart="8dp"
                            app:helperText="Auto-calculated"
                            app:helperTextTextColor="@color/splash_text_secondary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/batch_input"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@android:color/white"
                                android:inputType="text" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Academic Year -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Academic Year"
                        app:boxBackgroundColor="#22FFFFFF"
                        app:boxStrokeColor="@color/splash_accent"
                        app:hintTextColor="@color/splash_accent"
                        app:startIconDrawable="@drawable/ic_calendar"
                        app:startIconTint="@color/splash_accent"
                        android:layout_marginTop="16dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/academic_year_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@android:color/white"
                            android:inputType="text"
                            android:text="2025-2026" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#22FFFFFF"
                        android:layout_marginVertical="20dp" />

                    <!-- Info Text -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="#22FFFFFF"
                        android:padding="12dp"
                        android:layout_marginBottom="20dp">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_info"
                            app:tint="@color/splash_accent" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="• Invite code will be auto-generated"
                                android:textColor="@color/splash_text_secondary"
                                android:textSize="12sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="• Batch is calculated based on course duration"
                                android:textColor="@color/splash_text_secondary"
                                android:textSize="12sp"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="• Class will auto-complete after final semester"
                                android:textColor="@color/splash_text_secondary"
                                android:textSize="12sp"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Create Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_create"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="Create Class"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:icon="@drawable/ic_add"
                        app:iconGravity="textStart"
                        app:iconSize="24dp"
                        app:backgroundTint="@color/splash_accent"
                        android:textColor="@android:color/white" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:id="@+id/loading_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
