<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_gradient_background"
    android:fitsSystemWindows="true"
    tools:openDrawer="start">

    <!-- Main Content -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Animated Stars Background Layer -->
        <FrameLayout
            android:id="@+id/stars_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/dashboard_star1"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="80dp"
                android:layout_marginEnd="50dp"
                android:alpha="0.6"
                android:contentDescription="@null"
                android:src="@drawable/ic_star" />

            <ImageView
                android:id="@+id/dashboard_star2"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_gravity="top|start"
                android:layout_marginStart="40dp"
                android:layout_marginTop="120dp"
                android:alpha="0.5"
                android:contentDescription="@null"
                android:src="@drawable/ic_star" />

            <ImageView
                android:id="@+id/dashboard_star3"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="150dp"
                android:alpha="0.7"
                android:contentDescription="@null"
                android:src="@drawable/ic_star" />

            <ImageView
                android:id="@+id/dashboard_star4"
                android:layout_width="11dp"
                android:layout_height="11dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="30dp"
                android:alpha="0.6"
                android:contentDescription="@null"
                android:src="@drawable/ic_star" />

            <ImageView
                android:id="@+id/dashboard_star5"
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:layout_gravity="center_vertical|start"
                android:layout_marginStart="60dp"
                android:alpha="0.4"
                android:contentDescription="@null"
                android:src="@drawable/ic_star" />

            <ImageView
                android:id="@+id/dashboard_star6"
                android:layout_width="13dp"
                android:layout_height="13dp"
                android:layout_gravity="top|start"
                android:layout_marginStart="120dp"
                android:layout_marginTop="200dp"
                android:alpha="0.5"
                android:contentDescription="@null"
                android:src="@drawable/ic_star" />

            <ImageView
                android:id="@+id/dashboard_star7"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="250dp"
                android:layout_marginEnd="80dp"
                android:alpha="0.6"
                android:contentDescription="@null"
                android:src="@drawable/ic_star" />

            <ImageView
                android:id="@+id/dashboard_star8"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="70dp"
                android:layout_marginBottom="180dp"
                android:alpha="0.5"
                android:contentDescription="@null"
                android:src="@drawable/ic_star" />

            <ImageView
                android:id="@+id/dashboard_star9"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="bottom|end"
                android:layout_marginEnd="60dp"
                android:layout_marginBottom="220dp"
                android:alpha="0.7"
                android:contentDescription="@null"
                android:src="@drawable/ic_star" />

            <ImageView
                android:id="@+id/dashboard_star10"
                android:layout_width="11dp"
                android:layout_height="11dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="280dp"
                android:alpha="0.6"
                android:contentDescription="@null"
                android:src="@drawable/ic_star" />

            <ImageView
                android:id="@+id/dashboard_star11"
                android:layout_width="9dp"
                android:layout_height="9dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="300dp"
                android:layout_marginEnd="120dp"
                android:alpha="0.4"
                android:contentDescription="@null"
                android:src="@drawable/ic_star" />

            <ImageView
                android:id="@+id/dashboard_star12"
                android:layout_width="13dp"
                android:layout_height="13dp"
                android:layout_gravity="top|start"
                android:layout_marginStart="50dp"
                android:layout_marginTop="400dp"
                android:alpha="0.5"
                android:contentDescription="@null"
                android:src="@drawable/ic_star" />

        </FrameLayout>

        <!-- AppBar -->
        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/app_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@drawable/toolbar_gradient"
                android:elevation="4dp"
                app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
                app:title="COE Dashboard"
                app:titleTextColor="@android:color/white" />

        </com.google.android.material.appbar.AppBarLayout>

        <!-- Main Dashboard Content -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Overview Section Header with Line -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:shadowColor="#6C63FF"
                        android:shadowRadius="8"
                        android:text="Overview"
                        android:textColor="@android:color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="2dp"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:background="@drawable/header_line_gradient" />
                </LinearLayout>

                <!-- Stats Cards Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Total Students Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="#33667EEA"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/card_glass_effect"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <!-- Card Label -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.7"
                                android:letterSpacing="0.1"
                                android:text="STUDENTS"
                                android:textColor="@android:color/white"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="30dp"
                                android:layout_height="2dp"
                                android:layout_marginTop="4dp"
                                android:layout_marginBottom="8dp"
                                android:alpha="0.5"
                                android:background="@android:color/white" />

                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/ic_students"
                                app:tint="@android:color/white" />

                            <TextView
                                android:id="@+id/total_students"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:shadowColor="#667EEA"
                                android:shadowRadius="8"
                                android:text="1,258"
                                android:textColor="@android:color/white"
                                android:textSize="28sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.8"
                                android:text="Total Enrolled"
                                android:textColor="@android:color/white"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Total Faculty Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="#336C63FF"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/card_glass_effect"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <!-- Card Label -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.7"
                                android:letterSpacing="0.1"
                                android:text="FACULTY"
                                android:textColor="@android:color/white"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="30dp"
                                android:layout_height="2dp"
                                android:layout_marginTop="4dp"
                                android:layout_marginBottom="8dp"
                                android:alpha="0.5"
                                android:background="@android:color/white" />

                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/ic_faculty"
                                app:tint="@android:color/white" />

                            <TextView
                                android:id="@+id/total_faculty"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:shadowColor="#6C63FF"
                                android:shadowRadius="8"
                                android:text="102"
                                android:textColor="@android:color/white"
                                android:textSize="28sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.8"
                                android:text="Teaching Staff"
                                android:textColor="@android:color/white"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Stats Cards Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Total Departments Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="#334FACFE"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/card_glass_effect"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <!-- Card Label -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.7"
                                android:letterSpacing="0.1"
                                android:text="DEPARTMENTS"
                                android:textColor="@android:color/white"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="30dp"
                                android:layout_height="2dp"
                                android:layout_marginTop="4dp"
                                android:layout_marginBottom="8dp"
                                android:alpha="0.5"
                                android:background="@android:color/white" />

                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/ic_departments"
                                app:tint="@android:color/white" />

                            <TextView
                                android:id="@+id/total_departments"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:shadowColor="#4FACFE"
                                android:shadowRadius="8"
                                android:text="12"
                                android:textColor="@android:color/white"
                                android:textSize="28sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.8"
                                android:text="Academic Units"
                                android:textColor="@android:color/white"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Total Classes Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="140dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="#335B7CFF"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/card_glass_effect"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <!-- Card Label -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.7"
                                android:letterSpacing="0.1"
                                android:text="CLASSES"
                                android:textColor="@android:color/white"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                            <View
                                android:layout_width="30dp"
                                android:layout_height="2dp"
                                android:layout_marginTop="4dp"
                                android:layout_marginBottom="8dp"
                                android:alpha="0.5"
                                android:background="@android:color/white" />

                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/ic_classes"
                                app:tint="@android:color/white" />

                            <TextView
                                android:id="@+id/total_classes"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:shadowColor="#5B7CFF"
                                android:shadowRadius="8"
                                android:text="48"
                                android:textColor="@android:color/white"
                                android:textSize="28sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:alpha="0.8"
                                android:text="Active Groups"
                                android:textColor="@android:color/white"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>


                <!-- Analytics Cards -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Average Attendance -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="#331A1A3E"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/card_glass_effect"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:id="@+id/avg_attendance"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:shadowColor="#667EEA"
                                android:shadowRadius="8"
                                android:text="87.5%"
                                android:textColor="#667EEA"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:alpha="0.8"
                                android:text="Avg Attendance"
                                android:textColor="@android:color/white"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Average Exam Marks -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        app:cardBackgroundColor="#331A1A3E"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/card_glass_effect"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:id="@+id/avg_exam_marks"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:shadowColor="#6C63FF"
                                android:shadowRadius="8"
                                android:text="72.3%"
                                android:textColor="#6C63FF"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:alpha="0.8"
                                android:text="Avg Exam Marks"
                                android:textColor="@android:color/white"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Pending Complaints Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#331A1A3E"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/card_glass_effect"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:padding="8dp"
                            android:src="@drawable/ic_complaints"
                            app:tint="#4FACFE" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pending Complaints"
                                android:textColor="@android:color/white"
                                android:textSize="14sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/pending_complaints"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:alpha="0.7"
                                android:text="7 complaints need attention"
                                android:textColor="@android:color/white"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/complaints_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:shadowColor="#4FACFE"
                            android:shadowRadius="8"
                            android:text="7"
                            android:textColor="#4FACFE"
                            android:textSize="32sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Quick Actions Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="12dp"
                    android:shadowColor="#6C63FF"
                    android:shadowRadius="8"
                    android:text="Quick Actions"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Quick Action Buttons Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Row 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btn_attendance"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardBackgroundColor="#331A1A3E"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="4dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/card_glass_effect"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <ImageView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:src="@drawable/ic_attendance"
                                    app:tint="#667EEA" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="Attendance"
                                    android:textAlignment="center"
                                    android:textColor="@android:color/white"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btn_exams"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_marginStart="6dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardBackgroundColor="#331A1A3E"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="4dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/card_glass_effect"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <ImageView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:src="@drawable/ic_exams"
                                    app:tint="#6C63FF" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="Exams"
                                    android:textAlignment="center"
                                    android:textColor="@android:color/white"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btn_timetable"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardBackgroundColor="#331A1A3E"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="4dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/card_glass_effect"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="12dp">

                                <ImageView
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:src="@drawable/ic_timetable"
                                    app:tint="#4FACFE" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="8dp"
                                    android:text="Timetable"
                                    android:textAlignment="center"
                                    android:textColor="@android:color/white"
                                    android:textSize="11sp"
                                    android:textStyle="bold" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <!-- Row 2 -->

                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#1A1A3E"
        app:headerLayout="@layout/nav_header_coe"
        app:itemIconTint="@color/splash_accent"
        app:itemTextColor="@android:color/white"
        app:menu="@menu/coe_drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
