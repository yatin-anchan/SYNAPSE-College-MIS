<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_hod_marks_moderation.xml

    Preserved from previous fixed version (document 5):
    1. NO android:descendantFocusability="blocksDescendants" on RecyclerView
    2. NestedScrollView uses beforeDescendants + focusableInTouchMode
    3. Bottom buttons container slides away on keyboard open

    New additions (inserted after the horizontal divider in exam_info_card):
    4. exam_type_chip  — "Written / Internal / Combined" badge
    5. marks_scheme_text — "Written: 70  |  Internal: 30  |  Total: 100"
    6. 4-column header row — Orig.(Wrt.) / Orig.(Int.) / New(Wrt.) / New(Int.) / Abs.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@drawable/splash_gradient_background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/toolbar_gradient"
            app:titleTextColor="@android:color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <!--
        FIX (from doc 5): beforeDescendants + focusableInTouchMode prevents the
        NestedScrollView from stealing focus from RecyclerView item EditTexts,
        which was the root cause of the NPE crash.
    -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true"
        android:descendantFocusability="beforeDescendants"
        android:focusableInTouchMode="true"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- ═══ Exam Info Card ═══════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/exam_info_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="12dp"
                app:cardBackgroundColor="#551A1A3E">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_glass_effect"
                    android:padding="24dp">

                    <!-- Icon + exam / subject names (unchanged) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:background="@drawable/circle_gradient"
                            android:padding="14dp"
                            android:src="@drawable/ic_school"
                            app:tint="@color/white" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="20dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/exam_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mid Semester Exam"
                                android:textColor="@android:color/white"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/subject_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Data Structures (Max: 100 marks)"
                                android:textColor="#E0FFFFFF"
                                android:textSize="14sp"
                                android:layout_marginTop="6dp" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/lock_icon"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_lock"
                            android:visibility="gone"
                            app:tint="@android:color/holo_orange_dark" />
                    </LinearLayout>

                    <!-- Horizontal divider (unchanged) -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="#33FFFFFF"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="16dp" />

                    <!-- ══ NEW: exam type chip ═══════════════════════════════ -->
                    <com.google.android.material.chip.Chip
                        android:id="@+id/exam_type_chip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Written"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:layout_marginBottom="6dp"
                        app:chipBackgroundColor="#4466BBFF"
                        app:chipStrokeColor="#6688CCFF"
                        app:chipStrokeWidth="1dp"
                        app:ensureMinTouchTargetSize="false" />

                    <!-- ══ NEW: marks scheme line ════════════════════════════ -->
                    <TextView
                        android:id="@+id/marks_scheme_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Total: 100"
                        android:textColor="@color/splash_accent"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp" />

                    <!-- ══ NEW: 4-column header for moderation table ═════════ -->
                    <!--  Labels: original values | moderated (editable) values  -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="#22FFFFFF"
                        android:paddingVertical="5dp"
                        android:paddingHorizontal="4dp"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2.2"
                            android:text="Student"
                            android:textColor="#CCFFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <!-- Original written marks (read-only reference) -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Orig.\n(Wrt.)"
                            android:textColor="#CCFFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <!-- Original internal marks (read-only reference) -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="Orig.\n(Int.)"
                            android:textColor="#CCFFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <!-- New written marks (editable) -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.1"
                            android:gravity="center"
                            android:text="New\n(Wrt.)"
                            android:textColor="@color/splash_accent"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <!-- New internal marks (editable) -->
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.1"
                            android:gravity="center"
                            android:text="New\n(Int.)"
                            android:textColor="@color/splash_accent"
                            android:textSize="10sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.6"
                            android:gravity="center"
                            android:text="Abs."
                            android:textColor="#CCFFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Status + Stats row (unchanged) -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/status_text"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="⚠️ Not Moderated"
                            android:textColor="@android:color/holo_red_light"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/stats_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="45 students | 0 modified"
                            android:textColor="@color/splash_accent"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:gravity="end" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ═══ Collapsible Filter Card (unchanged from doc 5) ══════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/filter_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#441A1A3E">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_glass_effect">

                    <!-- Filter Header (Always Visible) -->
                    <LinearLayout
                        android:id="@+id/filter_header_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="20dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🔍 Filters &amp; Sorting"
                            android:textColor="@android:color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/filter_toggle_icon"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@android:drawable/arrow_down_float"
                            app:tint="@android:color/white" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#22FFFFFF" />

                    <!-- Filter Content (Collapsible) -->
                    <LinearLayout
                        android:id="@+id/filter_content_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:visibility="gone">

                        <!-- Marks Range -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Marks Range"
                            android:textColor="#CCFFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp">

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginEnd="8dp"
                                app:boxBackgroundColor="#1AFFFFFF"
                                app:boxStrokeColor="@android:color/white"
                                app:hintTextColor="@android:color/white"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/filter_marks_min"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="Min"
                                    android:inputType="numberDecimal"
                                    android:textColor="@android:color/white"
                                    android:textColorHint="#99FFFFFF" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="8dp"
                                app:boxBackgroundColor="#1AFFFFFF"
                                app:boxStrokeColor="@android:color/white"
                                app:hintTextColor="@android:color/white"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">

                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/filter_marks_max"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:hint="Max"
                                    android:inputType="numberDecimal"
                                    android:textColor="@android:color/white"
                                    android:textColorHint="#99FFFFFF" />
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <!-- Student Filters -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Student Filters"
                            android:textColor="#CCFFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="12dp"
                            app:boxBackgroundColor="#1AFFFFFF"
                            app:boxStrokeColor="@android:color/white"
                            app:hintTextColor="@android:color/white"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/filter_roll_no"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Roll Number"
                                android:inputType="text"
                                android:textColor="@android:color/white"
                                android:textColorHint="#99FFFFFF" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundColor="#1AFFFFFF"
                            app:boxStrokeColor="@android:color/white"
                            app:hintTextColor="@android:color/white"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/filter_name"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Student Name"
                                android:inputType="text"
                                android:textColor="@android:color/white"
                                android:textColorHint="#99FFFFFF" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <CheckBox
                            android:id="@+id/filter_absent_checkbox"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Show Only Absent"
                            android:textColor="@android:color/white"
                            android:buttonTint="@android:color/white"
                            android:layout_marginBottom="8dp" />

                        <CheckBox
                            android:id="@+id/filter_modified_checkbox"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Show Only Modified"
                            android:textColor="@android:color/white"
                            android:buttonTint="@android:color/white"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sort By"
                            android:textColor="#CCFFFFFF"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <Spinner
                            android:id="@+id/sort_spinner"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginBottom="20dp"
                            android:background="@drawable/spinner_background"
                            android:popupBackground="@drawable/card_glass_effect" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/filter_button"
                                android:layout_width="0dp"
                                android:layout_height="52dp"
                                android:layout_weight="1"
                                android:layout_marginEnd="12dp"
                                android:text="Apply Filters"
                                android:textAllCaps="false"
                                app:icon="@drawable/ic_filter"
                                app:iconGravity="textStart"
                                app:backgroundTint="@color/splash_accent"
                                android:textColor="@android:color/white" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/clear_filter_button"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="52dp"
                                android:layout_weight="1"
                                android:layout_marginStart="12dp"
                                android:text="Clear"
                                android:textAllCaps="false"
                                app:strokeColor="@android:color/white"
                                android:textColor="@android:color/white" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!--
                FIX (from doc 5): NO descendantFocusability="blocksDescendants" here.
                That attribute was blocking all touch/focus on child EditTexts
                inside RecyclerView items, preventing marks entry.
            -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingHorizontal="16dp"
                android:paddingBottom="200dp"
                android:nestedScrollingEnabled="false" />

            <!-- Loading (unchanged) -->
            <ProgressBar
                android:id="@+id/loading_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="50dp"
                android:visibility="gone"
                android:indeterminateTint="@color/splash_accent" />

            <!-- Empty View (unchanged) -->
            <LinearLayout
                android:id="@+id/empty_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="40dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_marginBottom="20dp"
                    android:src="@drawable/ic_empty_draft"
                    app:tint="#66FFFFFF" />

                <TextView
                    android:id="@+id/empty_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No data available"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ═══ Bottom Action Buttons (unchanged from doc 5) ══════════════════ -->
    <LinearLayout
        android:id="@+id/bottom_buttons_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:elevation="12dp"
        android:background="@drawable/card_glass_effect">

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@drawable/gradient_divider" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/save_draft_button"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="💾 Save Draft"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:strokeColor="@android:color/white"
                app:strokeWidth="2dp"
                android:textColor="@android:color/white" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/submit_button"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="🔒 Submit &amp; Lock"
                android:textAllCaps="false"
                android:textSize="14sp"
                app:backgroundTint="@color/splash_accent"
                android:textColor="@android:color/white" />

        </LinearLayout>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>