<?xml version="1.0" encoding="utf-8"?>
<!--
    item_hod_marks_moderation_exam.xml
    Outer exam card for the HOD moderation list.
    Mirrors item_faculty_marks_exam.xml so both screens are consistent.
    Contains a nested RecyclerView (subjects_recycler_view) populated by
    HodMarksModerationListAdapter.SubjectsAdapter with item_hod_moderation_subject rows.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeWidth="1dp"
    app:strokeColor="#33FFFFFF"
    app:cardBackgroundColor="#1AFFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ── Exam Header ────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Exam icon -->
            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_grade"
                app:tint="@android:color/white"
                android:padding="10dp"
                android:background="@drawable/circle_background" />

            <!-- Exam name + date -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/exam_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mid Semester Exam"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/exam_date"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Exam Date: 20 Feb 2026"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/course_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="B.Tech Computer Science"
                    android:textColor="@color/splash_text_secondary"
                    android:textSize="12sp" />

            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFFFFF"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp" />

        <!-- ── Per-Subject Rows ──────────────────────────────────────── -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/subjects_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:clipToPadding="false" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>