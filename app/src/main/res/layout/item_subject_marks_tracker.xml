<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/subject_card"
    android:layout_width="120dp"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeWidth="2dp"
    app:strokeColor="#33FFFFFF"
    app:cardBackgroundColor="#2A1A1A3E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_glass_effect"
        android:padding="12dp"
        android:gravity="center">

        <!-- Subject Code -->
        <TextView
            android:id="@+id/subject_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CS101"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Divider line -->
        <View
            android:layout_width="32dp"
            android:layout_height="2dp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="8dp"
            android:background="@color/splash_accent"
            android:alpha="0.6" />

        <!-- Mini Circular Progress + count -->
        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/progress_bar"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                app:indicatorSize="52dp"
                app:indicatorColor="@color/splash_accent"
                app:trackColor="#33FFFFFF"
                app:trackThickness="5dp"
                android:progress="0" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/marks_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/0"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="done"
                    android:textSize="8sp"
                    android:textColor="#88FFFFFF"
                    android:gravity="center" />

            </LinearLayout>

        </FrameLayout>

        <!-- Mini horizontal stepper: 3 dots for Entered / Submitted / Moderated -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp">

            <!-- Mini dot 1 -->
            <FrameLayout
                android:id="@+id/mini_dot_1"
                android:layout_width="14dp"
                android:layout_height="14dp">
                <View
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:background="@drawable/stepper_dot_inactive" />
                <View
                    android:id="@+id/mini_dot_1_fill"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="center"
                    android:background="@drawable/stepper_dot_inactive_fill" />
            </FrameLayout>

            <!-- Line 1 -->
            <View
                android:id="@+id/mini_line_1"
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_weight="1"
                android:background="@drawable/stepper_line_inactive" />

            <!-- Mini dot 2 -->
            <FrameLayout
                android:id="@+id/mini_dot_2"
                android:layout_width="14dp"
                android:layout_height="14dp">
                <View
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:background="@drawable/stepper_dot_inactive" />
                <View
                    android:id="@+id/mini_dot_2_fill"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="center"
                    android:background="@drawable/stepper_dot_inactive_fill" />
            </FrameLayout>

            <!-- Line 2 -->
            <View
                android:id="@+id/mini_line_2"
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_weight="1"
                android:background="@drawable/stepper_line_inactive" />

            <!-- Mini dot 3 -->
            <FrameLayout
                android:id="@+id/mini_dot_3"
                android:layout_width="14dp"
                android:layout_height="14dp">
                <View
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:background="@drawable/stepper_dot_inactive" />
                <View
                    android:id="@+id/mini_dot_3_fill"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:layout_gravity="center"
                    android:background="@drawable/stepper_dot_inactive_fill" />
            </FrameLayout>

        </LinearLayout>

        <!-- Step micro-labels -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="In"
                android:textSize="8sp"
                android:textColor="#66FFFFFF"
                android:gravity="center" />

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Sub"
                android:textSize="8sp"
                android:textColor="#66FFFFFF"
                android:gravity="center" />

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mod"
                android:textSize="8sp"
                android:textColor="#66FFFFFF"
                android:gravity="center" />

        </LinearLayout>

        <!-- Status Chip -->
        <com.google.android.material.chip.Chip
            android:id="@+id/status_chip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Pending"
            android:textSize="9sp"
            android:textStyle="bold"
            android:gravity="center"
            app:chipMinHeight="24dp"
            app:chipCornerRadius="8dp"
            android:textColor="@android:color/white" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>