<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardStudentAttendances"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/splash_card_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Top Row: Name + Percent -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Left: Name & Roll -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvStudentName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Student Name"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/splash_text_primary"/>

                <TextView
                    android:id="@+id/tvStudentRolls"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Roll: 01"
                    android:textSize="13sp"
                    android:textColor="@color/splash_text_secondary"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <!-- Right: Percentage -->
            <TextView
                android:id="@+id/tvAttendancePercents"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="75%"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/splash_text_primary"/>
        </LinearLayout>

        <!-- Progress Bar -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/attendanceProgressBars"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="6dp"
            app:trackThickness="6dp"
            app:indicatorColor="@color/splash_primary"/>

        <!-- Status Chip -->
        <TextView
            android:id="@+id/tvAttendanceStatusChips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Safe"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/bg_chip_green"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"/>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>