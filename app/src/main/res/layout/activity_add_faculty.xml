<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_gradient_background"
    android:fitsSystemWindows="true">

    <!-- AppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:fitsSystemWindows="true">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/toolbar_gradient"
            app:title="Add Faculty"
            app:titleTextColor="@android:color/white"
            app:navigationIcon="?attr/homeAsUpIndicator" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header Text -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Faculty Information"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="20dp"
                android:shadowColor="#6C63FF"
                android:shadowRadius="8" />

            <!-- Employee ID Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#331A1A3E">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/card_glass_effect">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Employee ID"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:alpha="0.8"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/employee_id_layout"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="#1A1A3E"
                            app:boxStrokeColor="@color/splash_accent"
                            app:hintTextColor="@color/splash_text_secondary"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/employee_id_input"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="EMP001"
                                android:inputType="text"
                                android:textColor="@color/splash_text_color"
                                android:textColorHint="@color/splash_text_secondary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_generate_id"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="56dp"
                            android:text="Generate"
                            android:textColor="@color/splash_accent"
                            app:strokeColor="@color/splash_accent"
                            app:strokeWidth="2dp"
                            app:icon="@drawable/ic_auto_generate"
                            app:iconTint="@color/splash_accent" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Basic Information Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#331A1A3E">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/card_glass_effect">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Basic Information"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <!-- Full Name -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/name_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:boxBackgroundMode="outline"
                        app:boxBackgroundColor="#1A1A3E"
                        app:boxStrokeColor="@color/splash_accent"
                        app:hintTextColor="@color/splash_text_secondary"
                        app:startIconDrawable="@drawable/ic_person"
                        app:startIconTint="@color/splash_accent"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/name_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Full Name"
                            android:inputType="textPersonName"
                            android:textColor="@color/splash_text_color"
                            android:textColorHint="@color/splash_text_secondary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Email (Required) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/email_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:boxBackgroundMode="outline"
                        app:boxBackgroundColor="#1A1A3E"
                        app:boxStrokeColor="@color/splash_accent"
                        app:hintTextColor="@color/splash_text_secondary"
                        app:startIconDrawable="@drawable/ic_email"
                        app:startIconTint="@color/splash_accent"
                        app:errorEnabled="true"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/email_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Email Address *"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/splash_text_color"
                            android:textColorHint="@color/splash_text_secondary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Mobile Number (Required) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/mobile_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:boxBackgroundMode="outline"
                        app:boxBackgroundColor="#1A1A3E"
                        app:boxStrokeColor="@color/splash_accent"
                        app:hintTextColor="@color/splash_text_secondary"
                        app:startIconDrawable="@drawable/ic_phone"
                        app:startIconTint="@color/splash_accent"
                        app:errorEnabled="true"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/mobile_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Mobile Number *"
                            android:inputType="phone"
                            android:maxLength="10"
                            android:textColor="@color/splash_text_color"
                            android:textColorHint="@color/splash_text_secondary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Department Dropdown -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/department_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        app:boxBackgroundMode="outline"
                        app:boxBackgroundColor="#1A1A3E"
                        app:boxStrokeColor="@color/splash_accent"
                        app:hintTextColor="@color/splash_text_secondary"
                        app:startIconDrawable="@drawable/ic_departments"
                        app:startIconTint="@color/splash_accent"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                        <AutoCompleteTextView
                            android:id="@+id/department_dropdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Department"
                            android:inputType="none"
                            android:textColor="@color/splash_text_color"
                            android:textColorHint="@color/splash_text_secondary" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Role Dropdown -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/role_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        app:boxStrokeColor="@color/splash_accent"
                        app:hintTextColor="@color/splash_accent"
                        android:hint="Role">

                        <AutoCompleteTextView
                            android:id="@+id/role_dropdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:textColor="@android:color/white" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Designation -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/designation_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxBackgroundMode="outline"
                        app:boxBackgroundColor="#1A1A3E"
                        app:boxStrokeColor="@color/splash_accent"
                        app:hintTextColor="@color/splash_text_secondary"
                        app:startIconDrawable="@drawable/ic_work"
                        app:startIconTint="@color/splash_accent"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/designation_input"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Designation"
                            android:inputType="text"
                            android:textColor="@color/splash_text_color"
                            android:textColorHint="@color/splash_text_secondary" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Note Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#33667EEA">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_info"
                        app:tint="@android:color/white"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="An invitation email will be sent to the faculty to complete their profile and set up their account."
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:alpha="0.9" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Create Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_create_faculty"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Create Faculty Account"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                app:cornerRadius="12dp"
                app:backgroundTint="@color/splash_accent"
                android:textColor="@android:color/white"
                android:elevation="4dp"
                app:icon="@drawable/ic_send"
                app:iconTint="@android:color/white"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp" />

            <!-- Loading Progress -->
            <ProgressBar
                android:id="@+id/loading_progress"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/splash_accent"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
