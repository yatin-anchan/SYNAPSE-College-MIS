<?xml version="1.0" encoding="utf-8"?>
<!--
    item_hod_moderation_subject.xml  — FIXED
    Bugs fixed:
      1. "Max Marks" was wrapping vertically because drawableStart pushed width
         beyond what the constrained column allowed. Fix: removed drawableStart,
         kept info column as layout_weight=1 so it always gets remaining space.
      2. Subject name over-truncating. Fix: maxLines=2, weight=1 column.
      3. Status badge was inside a wrapping LinearLayout with padding that stole
         width. Fix: status_text is now a direct child with minWidth=110dp.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/subject_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="14dp"
    app:cardElevation="4dp"
    app:strokeWidth="2dp"
    app:cardBackgroundColor="#1AFFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="14dp"
        android:paddingVertical="14dp"
        android:gravity="center_vertical">

        <!-- Subject Icon — fixed 44dp, never shrinks -->
        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/circle_background"
            android:padding="10dp"
            android:src="@drawable/ic_book"
            app:tint="@color/white" />

        <!-- Subject name + max marks — takes all remaining space -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/subject_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Subject Name"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/max_marks"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Max Marks: 100"
                android:textColor="@color/splash_text_secondary"
                android:textSize="12sp"
                android:singleLine="true" />

        </LinearLayout>

        <!-- Status badge — fixed minWidth, no wrapping parent -->
        <TextView
            android:id="@+id/status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="110dp"
            android:gravity="center"
            android:text="Pending"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingHorizontal="10dp"
            android:paddingVertical="6dp"
            android:background="@drawable/rounded_corner_background"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Arrow — fixed 20dp -->
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_arrow_forward"
            app:tint="@color/splash_accent"
            android:layout_marginStart="6dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>