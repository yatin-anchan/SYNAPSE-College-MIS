<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/splash_gradient_background"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@drawable/toolbar_gradient"
            app:title="Department Dashboard"
            app:titleTextColor="@android:color/white"
            app:navigationIcon="@drawable/ic_arrow_back" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Department Header Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#331A1A3E">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_glass_effect"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="4dp"
                            app:cardBackgroundColor="@color/splash_accent">

                            <ImageView
                                android:id="@+id/department_image"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_departments"
                                app:tint="@android:color/white" />
                        </com.google.android.material.card.MaterialCardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:id="@+id/department_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Department Name"
                                android:textColor="@android:color/white"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium" />

                            <TextView
                                android:id="@+id/department_code"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="DEPT-SRSCI-001"
                                android:textColor="#B8A8D8"
                                android:textSize="13sp"
                                android:fontFamily="monospace"
                                android:letterSpacing="0.05"
                                android:layout_marginTop="4dp" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginTop="10dp">

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/college_chip"
                                    android:layout_width="wrap_content"
                                    android:layout_height="35dp"
                                    android:text="Senior College"
                                    android:textSize="11sp"
                                    android:textColor="@android:color/white"
                                    app:chipMinHeight="28dp"
                                    app:chipBackgroundColor="#4A90E2"
                                    app:chipCornerRadius="14dp" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/stream_chip"
                                    android:layout_width="wrap_content"
                                    android:layout_height="35dp"
                                    android:text="Science"
                                    android:textSize="11sp"
                                    android:textColor="@android:color/white"
                                    android:layout_marginStart="6dp"
                                    app:chipMinHeight="28dp"
                                    app:chipBackgroundColor="#50C878"
                                    app:chipCornerRadius="14dp" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@drawable/gradient_divider"
                        android:layout_marginVertical="16dp" />

                    <LinearLayout
                        android:id="@+id/hod_click_area"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp"
                        android:padding="14dp"
                        android:background="@drawable/rounded_clickable_background"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_person"
                            app:tint="@color/splash_accent"
                            android:layout_marginEnd="12dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Head of Department"
                                android:textColor="#B8A8D8"
                                android:textSize="11sp"
                                android:textAllCaps="true"
                                android:letterSpacing="0.1" />

                            <TextView
                                android:id="@+id/hod_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Yatin Anchan"
                                android:textColor="@android:color/white"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Statistics Cards -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="3dp"
                            app:cardBackgroundColor="#1A1A3E">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp"
                                android:gravity="center">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    app:cardCornerRadius="12dp"
                                    app:cardElevation="0dp"
                                    app:cardBackgroundColor="#2A2A5E">

                                    <ImageView
                                        android:layout_width="28dp"
                                        android:layout_height="28dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_faculty"
                                        app:tint="@color/splash_accent" />
                                </com.google.android.material.card.MaterialCardView>

                                <TextView
                                    android:id="@+id/faculty_count"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="1 Faculty Members"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    android:gravity="center"
                                    android:layout_marginTop="12dp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="3dp"
                            app:cardBackgroundColor="#1A1A3E">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp"
                                android:gravity="center">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    app:cardCornerRadius="12dp"
                                    app:cardElevation="0dp"
                                    app:cardBackgroundColor="#2A2A5E">

                                    <ImageView
                                        android:layout_width="28dp"
                                        android:layout_height="28dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_students"
                                        app:tint="@color/splash_accent" />
                                </com.google.android.material.card.MaterialCardView>

                                <TextView
                                    android:id="@+id/student_count"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="3 Students"
                                    android:textColor="@android:color/white"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    android:gravity="center"
                                    android:layout_marginTop="12dp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/established_year"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Established: 01/01/2012"
                        android:textColor="#B8A8D8"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:layout_marginBottom="12dp"
                        android:drawableStart="@drawable/ic_calendar"
                        android:drawablePadding="6dp"
                        android:drawableTint="#B8A8D8" />

                    <TextView
                        android:id="@+id/description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Department description will appear here."
                        android:textColor="@color/splash_text_color"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        android:alpha="0.9" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Quick Actions Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_dashboard"
                    app:tint="@color/splash_accent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quick Actions"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginStart="10dp" />
            </LinearLayout>

            <!-- Action Cards Grid: 4 rows x 2 cols = 7 cards (last row has 1) -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="4"
                android:alignmentMode="alignBounds"
                android:columnOrderPreserved="false">

                <!-- Row 0: View Faculty | View Students -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_view_faculty"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_row="0"
                    android:layout_column="0"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="#331A1A3E"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/card_glass_effect"
                        android:padding="16dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="@color/splash_accent">

                            <ImageView
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_faculty"
                                app:tint="@android:color/white" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View Faculty"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginTop="12dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_view_students"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_row="0"
                    android:layout_column="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="#331A1A3E"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/card_glass_effect"
                        android:padding="16dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#4A90E2">

                            <ImageView
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_students"
                                app:tint="@android:color/white" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View Students"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginTop="12dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Row 1: Attendance | Timetable -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_attendance_reports"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_row="1"
                    android:layout_column="0"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="#331A1A3E"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/card_glass_effect"
                        android:padding="16dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#50C878">

                            <ImageView
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_attendance"
                                app:tint="@android:color/white" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Attendance"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginTop="12dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_timetable"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_row="1"
                    android:layout_column="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="#331A1A3E"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/card_glass_effect"
                        android:padding="16dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#FFA500">

                            <ImageView
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_timetable"
                                app:tint="@android:color/white" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Timetable"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginTop="12dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Row 2: Leave Requests | Classes -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_leave_approvals"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_row="2"
                    android:layout_column="0"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="#331A1A3E"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/card_glass_effect"
                        android:padding="16dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#9B59B6">

                            <ImageView
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_logout"
                                app:tint="@android:color/white" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Leave Requests"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginTop="12dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_view_classes"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_row="2"
                    android:layout_column="1"
                    android:layout_columnWeight="1"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="#331A1A3E"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/card_glass_effect"
                        android:padding="16dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#E74C3C">

                            <ImageView
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_class"
                                app:tint="@android:color/white" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Classes"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginTop="12dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Row 3: Statistics (spans both columns) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_department_stats"
                    android:layout_width="0dp"
                    android:layout_height="130dp"
                    android:layout_row="3"
                    android:layout_column="0"
                    android:layout_columnWeight="1"
                    android:layout_columnSpan="2"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    app:cardBackgroundColor="#331A1A3E"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/card_glass_effect"
                        android:padding="16dp">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            app:cardCornerRadius="14dp"
                            app:cardElevation="0dp"
                            app:cardBackgroundColor="#3498DB">

                            <ImageView
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_analytics"
                                app:tint="@android:color/white" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Statistics"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_marginTop="12dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="16dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:id="@+id/loading_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/splash_accent"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>