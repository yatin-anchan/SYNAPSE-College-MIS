<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:fitsSystemWindows="true"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#331A1A3E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_glass_effect"
        android:padding="16dp">

        <!-- Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_book"
                app:tint="@android:color/white"
                android:padding="8dp"
                android:background="@drawable/circle_gradient" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/subject_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Subject Name"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/course_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Course Name"
                    android:textColor="@color/splash_accent"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFFFFF"
            android:layout_marginVertical="12dp" />

        <!-- Date and Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/exam_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="15 Jan 2026"
                android:textColor="@color/splash_text_color"
                android:textSize="13sp"
                android:drawableStart="@drawable/ic_calendar"
                android:drawablePadding="6dp"
                android:drawableTint="@color/splash_text_secondary" />

            <TextView
                android:id="@+id/exam_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10:00 AM - 01:00 PM"
                android:textColor="@color/splash_text_color"
                android:textSize="13sp"
                android:drawableStart="@drawable/ic_time"
                android:drawablePadding="6dp"
                android:drawableTint="@color/splash_text_secondary" />
        </LinearLayout>

        <!-- Venue -->
        <TextView
            android:id="@+id/venue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Exam Hall A"
            android:textColor="@color/splash_text_color"
            android:textSize="13sp"
            android:drawableStart="@drawable/ic_location"
            android:drawablePadding="6dp"
            android:drawableTint="@color/splash_text_secondary"
            android:layout_marginBottom="8dp" />

        <!-- Max Marks -->
        <TextView
            android:id="@+id/max_marks"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Max Marks: 100"
            android:textColor="@color/splash_text_color"
            android:textSize="13sp"
            android:drawableStart="@drawable/ic_grade"
            android:drawablePadding="6dp"
            android:drawableTint="@color/splash_text_secondary" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFFFFF"
            android:layout_marginVertical="12dp" />

        <!-- Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <ImageView
                android:id="@+id/btn_edit"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_edit"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@android:color/holo_orange_light"
                android:contentDescription="Edit Subject" />

            <ImageView
                android:id="@+id/btn_delete"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_delete"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@android:color/holo_red_light"
                android:contentDescription="Delete Subject"
                android:layout_marginStart="8dp" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
