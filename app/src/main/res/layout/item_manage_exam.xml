<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:fitsSystemWindows="true"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#331A1A3E"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_glass_effect"
        android:padding="16dp">

        <!-- Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:src="@drawable/ic_exam"
                app:tint="@android:color/white"
                android:padding="10dp"
                android:background="@drawable/circle_gradient" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/exam_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Exam Name"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/exam_period"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="15 Jan - 25 Jan 2026"
                    android:textColor="@color/splash_text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <com.google.android.material.chip.Chip
                android:id="@+id/status_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confirmed"
                android:textSize="10sp"
                app:chipBackgroundColor="@android:color/holo_green_dark"
                android:textColor="@android:color/white" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFFFFF"
            android:layout_marginVertical="12dp" />

        <!-- Info Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.chip.Chip
                android:id="@+id/semester_chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sem 1"
                android:textSize="11sp"
                app:chipBackgroundColor="@color/splash_accent"
                android:textColor="@android:color/white"
                app:chipIcon="@drawable/ic_book"
                app:chipIconTint="@android:color/white" />

            <TextView
                android:id="@+id/subjects_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5 Subjects"
                android:textColor="@color/splash_text_color"
                android:textSize="12sp"
                android:layout_marginStart="12dp"
                android:layout_gravity="center_vertical" />
        </LinearLayout>

        <TextView
            android:id="@+id/academic_year"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2025-2026"
            android:textColor="@color/splash_text_color"
            android:textSize="13sp"
            android:layout_marginTop="8dp"
            android:drawableStart="@drawable/ic_calendar"
            android:drawablePadding="6dp"
            android:drawableTint="@color/splash_text_secondary" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFFFFF"
            android:layout_marginVertical="12dp" />

        <!-- Actions Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <ImageView
                android:id="@+id/btn_view"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_visibility"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/splash_accent"
                android:contentDescription="View Exam" />

            <ImageView
                android:id="@+id/btn_enter_marks"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_grade"
                android:padding="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@android:color/holo_orange_light"
                android:contentDescription="Enter Marks"
                android:layout_marginStart="8dp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
